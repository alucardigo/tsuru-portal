# Secrets do Portal Tsuru — NÃO COMMITAR VALORES REAIS
# Preencher via OCI Vault ou variáveis de ambiente na máquina de deploy.

RAILS_MASTER_KEY=$(cat config/master.key)

# GitHub Container Registry (ghcr.io)
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Banco de dados OCI PostgreSQL
DATABASE_URL=$DATABASE_URL
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# Chave da aplicação Rails
SECRET_KEY_BASE=$SECRET_KEY_BASE

# Integração Sankhya (obter com equipe Sankhya)
SANKHYA_OAUTH_CLIENT_ID=$SANKHYA_OAUTH_CLIENT_ID
SANKHYA_OAUTH_CLIENT_SECRET=$SANKHYA_OAUTH_CLIENT_SECRET
SANKHYA_X_TOKEN=$SANKHYA_X_TOKEN

# Oracle Object Storage (Customer Secret Key)
OCI_ACCESS_KEY_ID=$OCI_ACCESS_KEY_ID
OCI_SECRET_ACCESS_KEY=$OCI_SECRET_ACCESS_KEY
