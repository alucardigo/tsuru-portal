# Copie este arquivo para .env e preencha com suas credenciais locais.
# O arquivo .env NÃO é commitado (ver .gitignore).

# PostgreSQL local (desenvolvimento)
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Secrets Rails (gerado com: bundle exec rails secret)
SECRET_KEY_BASE=

# Sankhya (preencher após obter com equipe Sankhya)
SANKHYA_OAUTH_CLIENT_ID=
SANKHYA_OAUTH_CLIENT_SECRET=
SANKHYA_X_TOKEN=
SANKHYA_API_BASE_URL=https://api.sankhya.com.br

# OCI Object Storage
OCI_NAMESPACE=
OCI_ACCESS_KEY_ID=
OCI_SECRET_ACCESS_KEY=
