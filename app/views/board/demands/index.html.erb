<% content_for :title, "Decisões pendentes" %>
<% content_for :nav_active, "decisoes" %>
<% content_for :crumb, "Diretoria" %>
<% content_for :subtitle, "· #{@pagy.count} aguardando" %>

<div class="max-w-[1180px] mx-auto px-7 py-6">
  <%# Hero %>
  <div class="mb-5">
    <div class="text-[26px] font-semibold tracking-tight text-gray-900">Decisões da diretoria</div>
    <p class="text-[13px] text-gray-500 mt-1">
      Projetos com avaliação técnica concluída aguardando aprovação executiva para entrarem em execução.
    </p>
  </div>

  <%# Stats %>
  <%
    total_benefit = @demands.sum do |d|
      next 0 unless d.lei_do_bem_record
      res = Calculators::LeiDoBemBenefit.call(record: d.lei_do_bem_record)
      res.success? ? res.payload[:economia_tributaria].to_d : 0
    end
  %>
  <div class="grid grid-cols-3 gap-3 mb-6">
    <div class="tsuru-card p-4">
      <div class="subhead">Pendentes</div>
      <div class="text-[26px] font-semibold tracking-tight mt-1 text-gray-900"><%= @pagy.count %></div>
      <div class="text-[11px] text-gray-500 mt-0.5">Aguardando sua decisão</div>
    </div>
    <div class="tsuru-card p-4">
      <div class="subhead">Benefício fiscal estimado total</div>
      <div class="text-[26px] font-semibold tracking-tight mt-1 text-emerald-700">
        <%= number_to_currency(total_benefit, unit: "R$ ", separator: ",", delimiter: ".") %>
      </div>
      <div class="text-[11px] text-gray-500 mt-0.5">Soma de IRPJ/CSLL economizado</div>
    </div>
    <div class="tsuru-card p-4">
      <div class="subhead">Histórico de decisões</div>
      <div class="text-[26px] font-semibold tracking-tight mt-1 text-gray-900"><%= BoardDecision.count %></div>
      <div class="text-[11px] text-gray-500 mt-0.5">Total registrado no portal</div>
    </div>
  </div>

  <%# Lista de projetos %>
  <% if @demands.empty? %>
    <div class="tsuru-card p-12 text-center">
      <%= icon(:flag, size: 36, class_name: "mx-auto text-gray-300 mb-3") %>
      <div class="text-[14px] font-semibold text-gray-900">Nenhuma decisão pendente</div>
      <p class="text-[12.5px] text-gray-500 mt-1">Quando o time T&I concluir avaliações N2, os projetos aparecem aqui.</p>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @demands.each do |demand| %>
        <% record = demand.lei_do_bem_record %>
        <% benefit_payload = if record
                              res = Calculators::LeiDoBemBenefit.call(record: record)
                              res.success? ? res.payload : nil
                            end %>
        <div class="tsuru-card p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 text-[11px] text-gray-500">
                <span class="font-mono text-gray-700"><%= demand.codigo_display %></span>
                <span class="text-gray-300">·</span>
                <span><%= demand.user.display_name %></span>
                <span class="text-gray-300">·</span>
                <span>Avaliação concluída <%= time_ago_in_words(demand.updated_at) %> atrás</span>
              </div>
              <div class="mt-1 text-[15px] font-semibold text-gray-900"><%= demand.title %></div>
              <% if demand.barreira_tecnica.present? %>
                <p class="text-[12.5px] text-gray-700 mt-1.5 leading-relaxed line-clamp-2">
                  <strong>Barreira:</strong> <%= demand.barreira_tecnica.truncate(220) %>
                </p>
              <% end %>
            </div>
            <div class="text-right shrink-0">
              <% if benefit_payload %>
                <div class="subhead">Benefício estimado</div>
                <div class="text-[18px] font-semibold text-emerald-700 tabular-nums">
                  <%= number_to_currency(benefit_payload[:economia_tributaria], unit: "R$ ", separator: ",", delimiter: ".") %>
                </div>
              <% else %>
                <div class="text-[11px] text-gray-400 italic">Sem Lei do Bem</div>
              <% end %>
              <%= link_to "Analisar →", board_demand_path(demand), class: "tsuru-btn-primary !h-7 !text-[11.5px] !px-2.5 mt-2" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <nav aria-label="paginação" class="flex justify-center mt-5 text-[12px] text-gray-600">
        <%== @pagy.series_nav %>
      </nav>
    <% end %>
  <% end %>
</div>
