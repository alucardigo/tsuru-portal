<% content_for :title, "Gantt / Timeline" %>
<% content_for :crumb, @demand ? "Gantt de #{@demand.codigo_display}" : "Visão portfolio" %>
<% content_for :subtitle, "· #{@window_start.strftime('%d/%m/%y')} a #{@window_end.strftime('%d/%m/%y')}" %>

<%
  # Configurações visuais
  px_per_day  = 28
  row_height  = 26
  row_gap     = 4
  label_w     = 320
  top_pad     = 36
  total_h     = top_pad + @rows.size * (row_height + row_gap) + 12
  total_w     = label_w + @window_days * px_per_day
  date_to_x   = ->(date) { label_w + ((date.to_date - @window_start).to_i * px_per_day) }
  today_x     = date_to_x.call(@today)
%>

<div class="px-7 py-6 max-w-[1600px] mx-auto">
  <%# filtros / navegação %>
  <div class="mb-4 flex items-center gap-2">
    <%= link_to gantt_path, class: "tsuru-btn-ghost #{'!bg-gray-900 !text-white' unless @demand}" do %>Portfolio (todos os projetos)<% end %>
    <% recent = Demand.order(created_at: :desc).limit(6) %>
    <% recent.each do |d| %>
      <%= link_to gantt_path(demand: d.id), class: "tsuru-btn-ghost #{'!bg-gray-900 !text-white' if @demand&.id == d.id}" do %>
        <%= d.codigo_display %>
      <% end %>
    <% end %>
  </div>

  <% if @rows.empty? %>
    <div class="tsuru-card p-12 text-center text-[13px] text-gray-500">
      Nenhuma tarefa com datas para exibir.
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto" style="max-width: 100%">
      <svg viewBox="0 0 <%= total_w %> <%= total_h %>" width="<%= total_w %>" height="<%= total_h %>"
           xmlns="http://www.w3.org/2000/svg" font-family="ui-sans-serif,system-ui,sans-serif">
        <%# fundo dos dias (alternando cor para week-end) %>
        <% (0...@window_days).each do |d| %>
          <% day = @window_start + d.days %>
          <% bg = (day.saturday? || day.sunday?) ? "#f9fafb" : "#ffffff" %>
          <rect x="<%= label_w + d * px_per_day %>" y="0" width="<%= px_per_day %>" height="<%= total_h %>" fill="<%= bg %>"/>
        <% end %>

        <%# cabeçalho com datas (a cada N dias) %>
        <% step = @window_days > 90 ? 7 : (@window_days > 30 ? 3 : 1) %>
        <% (0...@window_days).step(step) do |d| %>
          <% day = @window_start + d.days %>
          <text x="<%= label_w + d * px_per_day + 2 %>" y="14" font-size="9" fill="#6b7280"><%= day.strftime("%d/%m") %></text>
          <line x1="<%= label_w + d * px_per_day %>" y1="20" x2="<%= label_w + d * px_per_day %>" y2="<%= total_h %>" stroke="#e5e7eb" stroke-width="1"/>
        <% end %>

        <%# linha vertical de "hoje" %>
        <% if @today >= @window_start && @today <= @window_end %>
          <line x1="<%= today_x %>" y1="0" x2="<%= today_x %>" y2="<%= total_h %>" stroke="#ef4444" stroke-width="2" stroke-dasharray="4,3"/>
          <text x="<%= today_x + 4 %>" y="32" font-size="9" fill="#ef4444" font-weight="600">HOJE</text>
        <% end %>

        <%# linha divisória labels x timeline %>
        <line x1="<%= label_w %>" y1="0" x2="<%= label_w %>" y2="<%= total_h %>" stroke="#d1d5db" stroke-width="1"/>

        <%# rows %>
        <% row_y = {} %>
        <% @rows.each_with_index do |row, idx| %>
          <% t = row[:task] %>
          <% y = top_pad + idx * (row_height + row_gap) %>
          <% row_y[t.id] = y + row_height / 2 %>
          <% x1 = date_to_x.call(row[:start].to_date) %>
          <% x2 = date_to_x.call(row[:finish].to_date) %>
          <% w  = [ x2 - x1, 6 ].max %>
          <%
            color = case t.kanban_status
                    when "concluida"     then "#16a34a"
                    when "em_andamento"  then "#4f46e5"
                    when "em_revisao"    then "#7c3aed"
                    when "a_fazer"       then "#0891b2"
                    when "backlog"       then "#9ca3af"
                    else "#6b7280"
                    end
            stroke = t.atrasada? ? "#dc2626" : color
            stroke_width = t.atrasada? ? 2 : 1
          %>

          <%# label %>
          <text x="6" y="<%= y + row_height/2 + 4 %>" font-size="11" fill="#111827">
            <% pre = @demand ? "" : "#{t.demand.codigo_display} · " %>
            <%= pre + t.title.to_s.truncate(40) %>
          </text>
          <text x="6" y="<%= y + row_height/2 + 17 %>" font-size="9" fill="#6b7280">
            <%= t.kanban_status_label %><%= " · #{t.assignee.name}" if t.assignee %>
          </text>

          <%# linha tracejada da grid sob a row %>
          <line x1="<%= label_w %>" y1="<%= y + row_height %>" x2="<%= total_w %>" y2="<%= y + row_height %>" stroke="#f3f4f6" stroke-width="1"/>

          <%# barra da tarefa %>
          <rect x="<%= x1 %>" y="<%= y + 4 %>" width="<%= w %>" height="<%= row_height - 8 %>"
                rx="4" ry="4"
                fill="<%= color %>" fill-opacity="0.85"
                stroke="<%= stroke %>" stroke-width="<%= stroke_width %>"/>
          <%# progresso baseado em horas (active vs estimated) %>
          <% if t.estimated_hours.to_f.positive? %>
            <% pct = [ t.spent_hours.to_f / t.estimated_hours.to_f, 1.0 ].min %>
            <rect x="<%= x1 %>" y="<%= y + 4 %>" width="<%= (w * pct).round %>" height="<%= row_height - 8 %>"
                  rx="4" ry="4" fill="<%= color %>" fill-opacity="0.4"/>
          <% end %>
          <%# label dentro da barra %>
          <% if w > 60 %>
            <text x="<%= x1 + 6 %>" y="<%= y + row_height/2 + 3 %>" font-size="10" fill="#ffffff" font-weight="600"><%= t.title.to_s.truncate(20) %></text>
          <% end %>
        <% end %>

        <%# Setas de dependência (somente em view de demand) %>
        <% if @demand && @dependencies.any? %>
          <defs>
            <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#374151"/>
            </marker>
          </defs>
          <% @dependencies.each do |dep| %>
            <% pred_row = @rows.find { |r| r[:task].id == dep.predecessor_id } %>
            <% succ_row = @rows.find { |r| r[:task].id == dep.successor_id } %>
            <% next unless pred_row && succ_row && row_y[dep.predecessor_id] && row_y[dep.successor_id] %>
            <% from_x = date_to_x.call(pred_row[:finish].to_date) %>
            <% to_x   = date_to_x.call(succ_row[:start].to_date) %>
            <% from_y = row_y[dep.predecessor_id] %>
            <% to_y   = row_y[dep.successor_id] %>
            <path d="M <%= from_x %> <%= from_y %> L <%= from_x + 8 %> <%= from_y %> L <%= from_x + 8 %> <%= to_y %> L <%= to_x %> <%= to_y %>"
                  stroke="#374151" stroke-width="1.2" fill="none" marker-end="url(#arrow)"/>
          <% end %>
        <% end %>
      </svg>
    </div>

    <%# legenda %>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-[11px] text-gray-600">
      <span><span class="inline-block w-3 h-3 rounded mr-1" style="background:#9ca3af"></span>Backlog</span>
      <span><span class="inline-block w-3 h-3 rounded mr-1" style="background:#0891b2"></span>A fazer</span>
      <span><span class="inline-block w-3 h-3 rounded mr-1" style="background:#4f46e5"></span>Em andamento</span>
      <span><span class="inline-block w-3 h-3 rounded mr-1" style="background:#7c3aed"></span>Em revisão</span>
      <span><span class="inline-block w-3 h-3 rounded mr-1" style="background:#16a34a"></span>Concluída</span>
      <span><span class="inline-block w-3 h-3 rounded border-2 border-red-600 mr-1" style="background:white"></span>Atrasada</span>
      <% if @demand %><span><span class="inline-block w-4 h-1 mr-1 align-middle" style="background:#374151"></span>Dependência</span><% end %>
    </div>
  <% end %>
</div>
