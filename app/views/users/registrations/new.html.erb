<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-primary-900">Criar conta</h1>
      <p class="text-sm text-gray-500 mt-1">Portal de Inovação Tsuru</p>
    </div>

    <div class="tsuru-card">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "users/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :name, "Nome completo", class: "tsuru-label" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "tsuru-input" %>
        </div>

        <div>
          <%= f.label :email, "E-mail corporativo", class: "tsuru-label" %>
          <%= f.email_field :email, autocomplete: "email", class: "tsuru-input" %>
        </div>

        <div>
          <%= f.label :password, "Senha", class: "tsuru-label" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-400 mb-1">Mínimo <%= @minimum_password_length %> caracteres</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "tsuru-input" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar senha", class: "tsuru-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "tsuru-input" %>
        </div>

        <%= f.submit "Criar conta", class: "tsuru-btn-primary w-full" %>
      <% end %>
    </div>

    <p class="text-center text-sm text-gray-500 mt-4">
      Já tem conta?
      <%= link_to "Entrar", new_session_path(resource_name), class: "text-primary-700 hover:underline" %>
    </p>
  </div>
</div>
