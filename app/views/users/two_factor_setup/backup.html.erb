<% content_for :title, t("two_factor_setup.enabled_title") %>
<% content_for :nav_active, "configuracoes" %>
<% content_for :crumb, "Segurança da conta" %>
<% content_for :subtitle, "· 2FA ativado" %>

<% content_for :actions do %>
  <%= link_to edit_user_registration_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>
    <%= icon(:cog, size: 12) %> Perfil
  <% end %>
<% end %>

<div class="max-w-[820px] mx-auto px-7 py-8">
  <%# === Cabeçalho de sucesso === %>
  <div class="flex items-start gap-3 mb-6">
    <div class="shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-full bg-emerald-50 ring-1 ring-emerald-100 text-emerald-600">
      <%= icon(:check, size: 20) %>
    </div>
    <div class="min-w-0">
      <div class="subhead text-emerald-700">Configuração concluída</div>
      <h1 class="mt-0.5 text-[24px] font-semibold tracking-tight text-gray-900 leading-tight"><%= t("two_factor_setup.enabled_title") %></h1>
      <p class="text-[13px] text-gray-500 mt-1.5 leading-relaxed max-w-2xl"><%= t("two_factor_setup.enabled_body") %></p>
    </div>
  </div>

  <%# === Card de backup codes === %>
  <div class="tsuru-card overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-amber-50/40 flex items-center gap-2.5">
      <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-amber-100 text-amber-700">
        <%= icon(:shield, size: 13) %>
      </span>
      <div>
        <div class="text-[10.5px] uppercase tracking-wider text-amber-700 font-medium">Importante</div>
        <div class="text-[13px] font-semibold text-gray-900"><%= t("two_factor_setup.save_backup") %></div>
      </div>
    </div>

    <div class="p-5">
      <div class="rounded-md bg-gray-50 border border-gray-200 p-4 font-mono text-[12.5px] text-gray-800 whitespace-pre-wrap break-all">
        <%= @backup_codes %>
      </div>

      <p class="mt-3 text-[12px] text-gray-600 leading-relaxed">
        Guarde estes códigos em um local seguro (gerenciador de senhas ou cofre físico). Cada código pode ser usado uma vez
        caso você perca o acesso ao seu app autenticador.
      </p>
    </div>

    <div class="px-5 py-3.5 border-t border-gray-100 bg-gray-50/40 flex items-center justify-between">
      <div class="text-[11.5px] text-gray-500 flex items-center gap-1.5">
        <%= icon(:check, size: 12, class_name: "text-emerald-600") %>
        Verificação em duas etapas ativa
      </div>
      <%= link_to t("two_factor_setup.done"), dashboard_path, class: "tsuru-btn-primary !h-8 !text-[12.5px]" %>
    </div>
  </div>
</div>
