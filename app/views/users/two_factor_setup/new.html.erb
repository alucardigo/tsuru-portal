<div class="max-w-lg mx-auto py-10 px-4">
  <h1 class="text-2xl font-semibold mb-6"><%= t("two_factor_setup.title") %></h1>

  <div class="tsuru-card mb-6">
    <p class="text-sm text-gray-600 mb-4"><%= t("two_factor_setup.scan_instructions") %></p>

    <div class="flex justify-center mb-4">
      <%= raw @qr_svg %>
    </div>

    <p class="text-xs text-gray-500 text-center mb-1"><%= t("two_factor_setup.manual_entry") %></p>
    <code class="block text-center text-sm font-mono bg-gray-100 rounded px-3 py-2 break-all"><%= @secret %></code>
  </div>

  <%= form_with url: users_two_factor_setup_path, method: :post do |f| %>
    <% if flash[:alert].present? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4 text-sm">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :otp_attempt, t("two_factor_setup.enter_code"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :otp_attempt,
            autocomplete: "one-time-code",
            inputmode: "numeric",
            pattern: "[0-9]{6}",
            maxlength: 6,
            autofocus: true,
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <%= f.submit t("two_factor_setup.verify"), class: "btn-primary w-full" %>
  <% end %>
</div>
