<% content_for :title, t("two_factor_setup.title") %>
<% content_for :nav_active, "configuracoes" %>
<% content_for :crumb, "Segurança da conta" %>
<% content_for :subtitle, "· Verificação em duas etapas" %>

<% content_for :actions do %>
  <%= link_to edit_user_registration_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>
    <%= icon(:arrow, size: 12, class_name: "rotate-180") %> Voltar ao perfil
  <% end %>
<% end %>

<div class="max-w-[820px] mx-auto px-7 py-8">
  <%# === Cabeçalho === %>
  <div class="mb-6">
    <div class="subhead">Segurança da conta</div>
    <h1 class="mt-1 text-[24px] font-semibold tracking-tight text-gray-900 leading-tight"><%= t("two_factor_setup.title") %></h1>
    <p class="text-[13px] text-gray-500 mt-1.5 leading-relaxed max-w-2xl">
      Adicione uma segunda camada de proteção à sua conta. Você precisará do seu autenticador toda vez que entrar no portal.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-5 items-start">
    <%# === Coluna esquerda — QR code + secret + form === %>
    <div class="tsuru-card overflow-hidden">
      <%# Passo 1: QR Code %>
      <div class="px-6 py-5 border-b border-gray-100">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-900 text-white text-[11px] font-semibold">1</span>
          <div class="text-[13.5px] font-semibold text-gray-900">Escaneie o QR code</div>
        </div>
        <p class="mt-1 ml-8 text-[12px] text-gray-500 leading-relaxed"><%= t("two_factor_setup.scan_instructions") %></p>

        <div class="mt-4 flex justify-center">
          <div class="p-3 bg-white rounded-lg border border-gray-200">
            <%= raw @qr_svg %>
          </div>
        </div>

        <div class="mt-4">
          <div class="text-[10.5px] uppercase tracking-wider text-gray-400 font-medium text-center"><%= t("two_factor_setup.manual_entry") %></div>
          <code class="mt-1 block text-center text-[12px] font-mono text-gray-700 bg-gray-50 rounded-md px-3 py-2 border border-gray-200 break-all select-all"><%= @secret %></code>
        </div>
      </div>

      <%# Passo 2: Verificação OTP %>
      <%= form_with url: users_two_factor_setup_path, method: :post, local: true, class: "px-6 py-5" do |f| %>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-900 text-white text-[11px] font-semibold">2</span>
          <div class="text-[13.5px] font-semibold text-gray-900">Confirme com um código</div>
        </div>
        <p class="mt-1 ml-8 text-[12px] text-gray-500 leading-relaxed">Digite o código de 6 dígitos exibido no seu aplicativo autenticador.</p>

        <% if flash[:alert].present? %>
          <div class="mt-4 rounded-md bg-rose-50 border border-rose-200 px-3 py-2.5 text-[12.5px] text-rose-700 flex items-start gap-2">
            <%= icon(:x, size: 14, class_name: "shrink-0 mt-0.5") %>
            <span><%= flash[:alert] %></span>
          </div>
        <% end %>

        <div class="mt-4">
          <%= f.label :otp_attempt, t("two_factor_setup.enter_code"), class: "tsuru-label" %>
          <%= f.text_field :otp_attempt,
                autocomplete: "one-time-code",
                inputmode: "numeric",
                pattern: "[0-9]{6}",
                maxlength: 6,
                autofocus: true,
                placeholder: "000000",
                class: "mt-1 tsuru-input text-center !h-12 !text-[20px] tracking-[0.4em] font-mono" %>
        </div>

        <%= f.submit t("two_factor_setup.verify"), class: "tsuru-btn-primary w-full mt-4 !h-10 !text-[13px]" %>
      <% end %>
    </div>

    <%# === Coluna direita — Card explicativo === %>
    <aside class="space-y-4">
      <div class="tsuru-card overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-100 bg-gray-50/40 flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-gray-900 text-white">
            <%= icon(:shield, size: 13) %>
          </span>
          <div class="text-[13px] font-semibold text-gray-900">Por que ativar 2FA?</div>
        </div>
        <div class="p-4 space-y-3.5 text-[12px] text-gray-700 leading-relaxed">
          <div>
            <div class="text-[11px] uppercase tracking-wider text-gray-500 font-medium mb-0.5">Proteção contra phishing</div>
            <p class="text-gray-600">Mesmo se sua senha vazar, o invasor não conseguirá entrar sem o segundo fator.</p>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-wider text-gray-500 font-medium mb-0.5">Conformidade corporativa</div>
            <p class="text-gray-600">Atende requisitos de segurança da ISO 27001 e da LGPD para acesso a dados sensíveis de PD&I.</p>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-wider text-gray-500 font-medium mb-0.5">Trilha auditável</div>
            <p class="text-gray-600">Todo acesso fica registrado e pode ser rastreado em caso de incidente.</p>
          </div>
        </div>
      </div>

      <div class="rounded-md bg-amber-50 ring-1 ring-amber-100 p-3.5 flex items-start gap-2.5">
        <%= icon(:bulb, size: 14, class_name: "text-amber-600 shrink-0 mt-0.5") %>
        <div class="text-[11.5px] text-amber-900 leading-relaxed">
          <div class="font-medium">Apps recomendados</div>
          <p class="mt-0.5 text-amber-800">Google Authenticator, Authy, 1Password ou Microsoft Authenticator.</p>
        </div>
      </div>
    </aside>
  </div>
</div>
