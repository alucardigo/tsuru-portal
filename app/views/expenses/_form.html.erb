<%= form_with model: expense, url: expense.persisted? ?
        demand_lei_do_bem_record_expense_path(demand, expense) :
        demand_lei_do_bem_record_expenses_path(demand),
      local: true, class: "space-y-3" do |f| %>
  <% if expense.errors.any? %>
    <div class="rounded-md bg-rose-50 ring-1 ring-rose-200 p-3 text-[12.5px] text-rose-800">
      <ul class="list-disc pl-5">
        <% expense.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :categoria, class: "tsuru-label" %>
      <%= f.select :categoria,
            options_for_select(Expense::CATEGORIAS.map { |c| [ c.humanize, c ] }, expense.categoria),
            { include_blank: "Selecione…" }, class: "tsuru-select mt-1" %>
    </div>
    <div>
      <%= f.label :data_competencia, "Data de competência", class: "tsuru-label" %>
      <%= f.date_field :data_competencia, class: "tsuru-input mt-1" %>
    </div>
  </div>

  <div>
    <%= f.label :descricao, "Descrição", class: "tsuru-label" %>
    <%= f.text_field :descricao, class: "tsuru-input mt-1",
          placeholder: "Ex: Salário do pesquisador João Silva (40h dedicação parcial)" %>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :valor, "Valor (R$)", class: "tsuru-label" %>
      <%= f.number_field :valor, class: "tsuru-input mt-1", step: 0.01, min: 0, placeholder: "0.00" %>
    </div>
    <div>
      <%= f.label :documento_fiscal, "Documento fiscal", class: "tsuru-label" %>
      <%= f.text_field :documento_fiscal, class: "tsuru-input mt-1 font-mono",
            placeholder: "NF-1234 ou Folha 03/2026" %>
    </div>
  </div>

  <div>
    <%= f.label :centro_resultado_sankhya, "Centro de resultado Sankhya (opcional)", class: "tsuru-label" %>
    <%= f.text_field :centro_resultado_sankhya, class: "tsuru-input mt-1 font-mono",
          placeholder: "CODCENCUS no Sankhya" %>
  </div>

  <div class="flex items-center justify-between pt-3 border-t border-gray-100">
    <%= link_to "Cancelar", demand_lei_do_bem_record_path(demand, tab: "expenses"), class: "text-[12.5px] text-gray-600 hover:text-gray-900" %>
    <%= f.submit (expense.persisted? ? "Salvar" : "Adicionar dispêndio"), class: "tsuru-btn-primary" %>
  </div>
<% end %>
