<header class="topbar">
  <div class="min-w-0">
    <% if crumb.present? %>
      <div class="topbar-crumb"><%= crumb %></div>
    <% end %>
    <div class="flex items-baseline gap-2 min-w-0">
      <div class="topbar-title"><%= title %></div>
      <% if subtitle.present? %>
        <div class="topbar-subtitle"><%= subtitle %></div>
      <% end %>
    </div>
  </div>
  <div class="flex items-center gap-1">
    <% if actions.present? %>
      <%= actions %>
    <% end %>
    <%= render "shared/notification_bell" %>
  </div>
</header>
