<% if notice.present? %>
  <div class="mx-auto max-w-[1180px] px-7 mt-3" role="alert" aria-live="polite"
       data-controller="dismissable">
    <div class="flex items-start gap-3 px-3.5 py-2.5 rounded-md bg-emerald-50 ring-1 ring-emerald-200 text-emerald-800 text-[12.5px]">
      <%= icon(:check, size: 16, class_name: "shrink-0 mt-0.5") %>
      <span class="flex-1"><%= notice %></span>
      <button type="button" data-action="click->dismissable#dismiss"
              class="shrink-0 -mr-1 -mt-0.5 p-1 rounded text-emerald-700/70 hover:text-emerald-900 hover:bg-emerald-100/60 transition leading-none"
              aria-label="Fechar notificação">
        <%= icon(:x, size: 14) %>
      </button>
    </div>
  </div>
<% end %>
<% if alert.present? %>
  <div class="mx-auto max-w-[1180px] px-7 mt-3" role="alert" aria-live="polite"
       data-controller="dismissable">
    <div class="flex items-start gap-3 px-3.5 py-2.5 rounded-md bg-rose-50 ring-1 ring-rose-200 text-rose-800 text-[12.5px]">
      <%= icon(:x, size: 16, class_name: "shrink-0 mt-0.5") %>
      <span class="flex-1"><%= alert %></span>
      <button type="button" data-action="click->dismissable#dismiss"
              class="shrink-0 -mr-1 -mt-0.5 p-1 rounded text-rose-700/70 hover:text-rose-900 hover:bg-rose-100/60 transition leading-none"
              aria-label="Fechar notificação">
        <%= icon(:x, size: 14) %>
      </button>
    </div>
  </div>
<% end %>
