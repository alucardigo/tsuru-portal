<% content_for :title, "Excluir usuário" %>
<% content_for :crumb, "Administração · Usuários" %>
<% content_for :subtitle, "· desligamento / realocação" %>

<%
  labels = {
    "demands" => "Demandas/projetos (autor)",
    "comments" => "Comentários em demandas",
    "demand_transitions" => "Transições de estado (ator)",
    "project_tasks" => "Tarefas criadas",
    "project_task_comments" => "Comentários em tarefas",
    "team_members" => "Vínculos Lei do Bem (equipe)",
    "project_task_time_entries" => "Apontamentos de horas",
    "defense_dossiers" => "Dossiês de defesa criados",
    "knowledge_articles" => "Artigos da biblioteca criados",
    "ai_reports" => "Relatórios de IA solicitados",
    "project_tasks_assignee" => "Tarefas atribuídas (responsável)",
    "project_task_watchers_removidos" => "Tarefas seguindo (será removido)",
    "project_task_assignees_removidos" => "Corresponsabilidades (será removido)",
    "project_task_comment_reactions_removidos" => "Reações em comentários (será removido)",
    "saved_task_views_removidos" => "Views salvas (será removido)",
    "notifications_removidos" => "Notificações (será removido)",
    "subordinados" => "Subordinados (superior será removido)",
  }
%>

<div class="max-w-[720px] mx-auto px-8 py-8">
  <div class="bg-white rounded-lg border border-gray-200 p-5 mb-4">
    <div class="flex items-center gap-3">
      <%= avatar(@user, size: 40) %>
      <div>
        <div class="text-[16px] font-semibold text-gray-900"><%= @user.display_name %></div>
        <div class="text-[12.5px] text-gray-500"><%= @user.email %> · <%= role_label(@user.role) %></div>
      </div>
    </div>
  </div>

  <% if @preview.empty? %>
    <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-4 text-[12.5px] text-emerald-800 mb-4">
      Este usuário não possui nenhum registro vinculado — pode ser excluído diretamente.
    </div>
  <% else %>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
      <div class="text-[12.5px] text-amber-900 font-medium mb-2">⚠️ Este usuário possui registros que precisam ser transferidos:</div>
      <ul class="text-[12.5px] text-amber-800 space-y-1">
        <% @preview.each do |key, count| %>
          <li>· <%= labels[key.to_s] || key.to_s.humanize %>: <strong><%= count %></strong></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: excluir_admin_user_path(@user), method: :post, local: true, class: "bg-white rounded-lg border border-gray-200 p-5 space-y-3" do %>
    <div>
      <label class="tsuru-label">Transferir tudo para</label>
      <select name="target_user_id" required class="tsuru-select mt-1">
        <option value="">— selecione o usuário destino —</option>
        <% @destinos.each do |d| %>
          <option value="<%= d.id %>"><%= d.display_name %> (<%= d.email %>)</option>
        <% end %>
      </select>
      <p class="text-[11px] text-gray-400 mt-1">
        Demandas, tarefas, comentários e dossiês passam a pertencer a este usuário.
        Vínculos de acompanhamento/notificações são apenas removidos.
      </p>
    </div>

    <div class="flex items-center justify-between pt-2">
      <%= link_to "Cancelar", admin_users_path, class: "text-[12.5px] text-gray-600 hover:text-gray-900" %>
      <button class="tsuru-btn-primary !bg-rose-600 hover:!bg-rose-700"
              data-turbo-confirm="Excluir #{@user.display_name} permanentemente? Esta ação não pode ser desfeita.">
        Transferir e excluir
      </button>
    </div>
  <% end %>
</div>
