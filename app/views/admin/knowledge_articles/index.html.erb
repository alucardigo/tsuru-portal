<% content_for :title, "Biblioteca PD&I — Admin" %>
<% content_for :crumb, "Administração" %>
<% content_for :subtitle, "· gerenciar artigos da biblioteca" %>
<% content_for :actions do %>
  <%= link_to biblioteca_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>Ver biblioteca<% end %>
<% end %>

<div class="px-7 py-6 max-w-[1100px] mx-auto grid grid-cols-3 gap-5">
  <div class="col-span-2 space-y-2">
    <% @articles.each do |a| %>
      <div class="bg-white rounded-lg border border-gray-200 p-3.5 flex items-center gap-3 <%= 'opacity-60' unless a.published %>">
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-medium text-gray-900 truncate"><%= a.title %></div>
          <div class="text-[11.5px] text-gray-500"><%= KnowledgeArticle::CATEGORY_LABELS[a.category] %></div>
        </div>
        <%= button_to admin_knowledge_article_path(a, published: !a.published), method: :patch,
              class: "tsuru-btn-ghost !h-7 !text-[11px] !px-2", form: { class: "inline" } do %><%= a.published ? "Despublicar" : "Publicar" %><% end %>
        <%= button_to admin_knowledge_article_path(a), method: :delete,
              data: { turbo_confirm: "Remover #{a.title}?" },
              class: "tsuru-btn-ghost !h-7 !text-[11px] !px-2 !text-rose-600", form: { class: "inline" } do %>×<% end %>
      </div>
    <% end %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 p-4 h-fit">
    <h2 class="text-[13px] font-semibold text-gray-900 mb-3">Novo artigo</h2>
    <%= form_with url: admin_knowledge_articles_path, method: :post, local: true, class: "space-y-3" do |f| %>
      <div>
        <label class="tsuru-label">Título</label>
        <input name="knowledge_article[title]" required class="tsuru-input mt-1">
      </div>
      <div>
        <label class="tsuru-label">Categoria</label>
        <select name="knowledge_article[category]" class="tsuru-select mt-1">
          <% KnowledgeArticle::CATEGORIES.each do |c| %>
            <option value="<%= c %>"><%= KnowledgeArticle::CATEGORY_LABELS[c] %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="tsuru-label">Conteúdo</label>
        <textarea name="knowledge_article[body]" rows="8" required class="tsuru-textarea mt-1"></textarea>
      </div>
      <button class="tsuru-btn-primary w-full">Criar artigo</button>
    <% end %>
  </div>
</div>
