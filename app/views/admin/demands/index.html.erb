<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-primary-900">Demandas — Painel Admin</h1>
    <div class="flex gap-3">
      <%= link_to "Usuários", admin_users_path, class: "tsuru-btn-secondary" %>
      <%= link_to "Exportar CSV", admin_demands_path(format: :csv, estado: params[:estado]),
            class: "tsuru-btn-secondary" %>
    </div>
  </div>

  <%# Formulário de busca avançada %>
  <%= form_with url: admin_demands_path, method: :get, local: true, class: "bg-gray-50 border rounded-lg p-4 mb-4 grid grid-cols-2 md:grid-cols-4 gap-3 items-end" do |f| %>
    <div>
      <%= f.label :q, "Buscar título", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= f.text_field :q, value: params[:q], placeholder: "palavra-chave…",
            class: "border rounded px-2 py-1 text-sm w-full" %>
    </div>
    <div>
      <%= f.label :trl, "TRL", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= f.select :trl, options_for_select([ [ "Qualquer", "" ] ] + (1..9).map { |n| [ "TRL #{n}", n ] }, params[:trl]),
            {}, class: "border rounded px-2 py-1 text-sm w-full" %>
    </div>
    <div>
      <%= f.label :data_ini, "De", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= f.date_field :data_ini, value: params[:data_ini], class: "border rounded px-2 py-1 text-sm w-full" %>
    </div>
    <div>
      <%= f.label :data_fim, "Até", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= f.date_field :data_fim, value: params[:data_fim], class: "border rounded px-2 py-1 text-sm w-full" %>
    </div>
    <div class="col-span-2 md:col-span-4 flex gap-2">
      <%= f.submit "Filtrar", class: "bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700" %>
      <%= link_to "Limpar", admin_demands_path, class: "text-gray-500 text-sm hover:underline self-center" %>
    </div>
  <% end %>

  <%# Filtro por estado %>
  <div class="flex flex-wrap gap-2 mb-4">
    <%= link_to "Todas", admin_demands_path(q: params[:q], trl: params[:trl], data_ini: params[:data_ini], data_fim: params[:data_fim]),
          class: "#{params[:estado].blank? ? 'tsuru-btn-primary' : 'tsuru-btn-secondary'} text-xs py-1" %>
    <% %w[rascunho submetida em_triagem n1_aprovada n1_reprovada n2_em_andamento n2_completa elegivel nao_elegivel cancelada].each do |estado| %>
      <%= link_to estado.humanize, admin_demands_path(estado: estado, q: params[:q], trl: params[:trl], data_ini: params[:data_ini], data_fim: params[:data_fim]),
            class: "#{params[:estado] == estado ? 'tsuru-btn-primary' : 'tsuru-btn-secondary'} text-xs py-1" %>
    <% end %>
  </div>

  <div class="tsuru-card">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 text-left text-gray-500">
          <th class="pb-2 pr-3">ID</th>
          <th class="pb-2 pr-3">Título</th>
          <th class="pb-2 pr-3">Solicitante</th>
          <th class="pb-2 pr-3">Estado</th>
          <th class="pb-2">Criada</th>
        </tr>
      </thead>
      <tbody>
        <% @demands.each do |demand| %>
          <tr class="border-b border-gray-100">
            <td class="py-2 pr-3 text-gray-400">#<%= demand.id %></td>
            <td class="py-2 pr-3">
              <%= link_to demand.title.truncate(50), demand_path(demand),
                    class: "text-primary-700 hover:underline" %>
            </td>
            <td class="py-2 pr-3 text-gray-600"><%= demand.user.display_name %></td>
            <td class="py-2 pr-3">
              <span class="tsuru-badge-<%= demand.aasm_state %>"><%= demand.aasm_state.humanize %></span>
            </td>
            <td class="py-2 text-gray-400"><%= l demand.created_at, format: :short %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
