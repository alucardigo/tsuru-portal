<% content_for :title, "Integração Sankhya" %>
<% content_for :crumb, "Administração" %>
<% content_for :subtitle, "· colaboradores, PJ, projetos e notas de serviço" %>

<div class="px-7 py-6 max-w-[1100px] mx-auto">
  <div class="mb-4 flex items-center gap-2 text-[12.5px]">
    <span class="w-2 h-2 rounded-full <%= @healthy ? 'bg-emerald-500' : 'bg-rose-500' %>"></span>
    <span class="text-gray-700">Gateway Sankhya: <%= @healthy ? "conectado" : "indisponível (verifique SANKHYA_CLIENT_ID/SECRET)" %></span>
  </div>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-[12px] text-amber-800 mb-4">
    ⚠️ Cada instalação Sankhya tem nomes de entidade/campo próprios. Ajuste "Entidade" e "Campos"
    abaixo para os nomes reais do seu Sankhya (ex: TGFPAR para parceiros, com CLASSIFICACAO indicando
    PJ) antes de sincronizar — os mapeamentos abaixo vêm com valores de exemplo, desabilitados.
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <div class="lg:col-span-2 space-y-2">
      <% @mappings.each do |m| %>
        <div class="bg-white rounded-lg border border-gray-200 p-3.5 <%= 'opacity-60' unless m.enabled %>">
          <div class="flex items-center justify-between gap-3 mb-2">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full <%= m.enabled ? 'bg-emerald-500' : 'bg-gray-300' %>"></span>
              <span class="text-[13px] font-semibold text-gray-900"><%= SankhyaMapping::KIND_LABELS[m.kind] %></span>
            </div>
            <div class="flex items-center gap-2">
              <% if m.enabled %>
                <%= button_to sync_admin_sankhya_mapping_path(m), method: :post,
                      class: "tsuru-btn-secondary !h-7 !text-[11px] !px-2", form: { class: "inline" } do %>⚡ Sincronizar agora<% end %>
              <% end %>
              <%= button_to admin_sankhya_mapping_path(m, enabled: !m.enabled), method: :patch,
                    class: "tsuru-btn-ghost !h-7 !text-[11px] !px-2", form: { class: "inline" } do %><%= m.enabled ? "Desabilitar" : "Habilitar" %><% end %>
              <%= button_to admin_sankhya_mapping_path(m), method: :delete,
                    data: { turbo_confirm: "Remover mapeamento #{SankhyaMapping::KIND_LABELS[m.kind]}? Registros já sincronizados também são apagados." },
                    class: "tsuru-btn-ghost !h-7 !text-[11px] !px-2 !text-rose-600", form: { class: "inline" } do %>×<% end %>
            </div>
          </div>

          <%= form_with model: m, url: admin_sankhya_mapping_path(m), method: :patch, local: true, class: "grid grid-cols-2 gap-2" do |f| %>
            <div>
              <label class="text-[10.5px] text-gray-500">Entidade Sankhya</label>
              <%= f.text_field :entidade_sankhya, class: "tsuru-input !h-8 !text-[12px]" %>
            </div>
            <div>
              <label class="text-[10.5px] text-gray-500">Critério (opcional)</label>
              <%= f.text_field :criterio, class: "tsuru-input !h-8 !text-[12px]", placeholder: "this.CLASSIFICACAO = 'PJ'" %>
            </div>
            <div>
              <label class="text-[10.5px] text-gray-500">Campo código</label>
              <%= f.text_field :campo_codigo, class: "tsuru-input !h-8 !text-[12px]" %>
            </div>
            <div>
              <label class="text-[10.5px] text-gray-500">Campo nome</label>
              <%= f.text_field :campo_nome, class: "tsuru-input !h-8 !text-[12px]" %>
            </div>
            <div class="col-span-2">
              <label class="text-[10.5px] text-gray-500">Campos extras (separados por vírgula)</label>
              <%= f.text_field :campos_extra, class: "tsuru-input !h-8 !text-[12px]" %>
            </div>
            <div class="col-span-2 flex justify-end">
              <%= f.submit "Salvar", class: "tsuru-btn-ghost !h-7 !text-[11px] !px-2" %>
            </div>
          <% end %>

          <div class="text-[11px] text-gray-500 mt-1.5 flex items-center gap-3">
            <span><%= m.sankhya_records.count %> registro(s) em cache</span>
            <% if m.last_synced_at %>
              <span>· última sync <%= time_ago_in_words(m.last_synced_at) %> atrás (<%= m.last_sync_count %> registros)</span>
            <% end %>
            <% if m.last_sync_error.present? %>
              <span class="text-rose-600">· erro: <%= m.last_sync_error.truncate(80) %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="bg-white rounded-lg border border-gray-200 p-4 h-fit">
      <h2 class="text-[13px] font-semibold text-gray-900 mb-3">Novo mapeamento</h2>
      <%= form_with url: admin_sankhya_mappings_path, method: :post, local: true, class: "space-y-3" do %>
        <div>
          <label class="tsuru-label">Tipo</label>
          <select name="sankhya_mapping[kind]" class="tsuru-select mt-1">
            <% (SankhyaMapping::KINDS - SankhyaMapping.pluck(:kind)).each do |k| %>
              <option value="<%= k %>"><%= SankhyaMapping::KIND_LABELS[k] %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label class="tsuru-label">Entidade Sankhya</label>
          <input name="sankhya_mapping[entidade_sankhya]" required placeholder="ex: TGFPAR" class="tsuru-input mt-1">
        </div>
        <div>
          <label class="tsuru-label">Campo código</label>
          <input name="sankhya_mapping[campo_codigo]" value="CODPARC" required class="tsuru-input mt-1">
        </div>
        <div>
          <label class="tsuru-label">Campo nome</label>
          <input name="sankhya_mapping[campo_nome]" value="NOMEPARC" required class="tsuru-input mt-1">
        </div>
        <button class="tsuru-btn-primary w-full">Criar mapeamento</button>
      <% end %>
    </div>
  </div>
</div>
