<% content_for :title, "Organograma" %>
<% content_for :nav_active, "usuarios" %>
<% content_for :crumb, "Administração" %>
<% content_for :subtitle, "· hierarquia por área" %>

<% content_for :actions do %>
  <%= link_to admin_users_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>
    <%= icon(:user, size: 12) %> Usuários
  <% end %>
<% end %>

<% pess = ->(u) {
     content_tag(:div, class: "flex items-center gap-2 py-1") do
       avatar(u, size: 22).to_s.html_safe +
       content_tag(:div) do
         content_tag(:div, u.display_name, class: "text-[12.5px] text-gray-900 leading-tight") +
         content_tag(:div, u.email, class: "text-[10.5px] text-gray-400 leading-tight")
       end
     end
   } %>

<div class="max-w-[1180px] mx-auto px-7 py-6 space-y-6">
  <div>
    <div class="subhead">Administração</div>
    <h1 class="mt-1 text-[22px] font-semibold tracking-tight text-gray-900">Organograma</h1>
    <p class="text-[12.5px] text-gray-500 mt-1 leading-relaxed max-w-2xl">
      Cada área tem um superior responsável que aprova as demandas daquela área. Abaixo, a árvore por área e a equipe vinculada (superior direto).
    </p>
  </div>

  <%# === Faixa institucional (cross-funcional) === %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <% [["Diretoria", @diretoria, "bg-gray-900"], ["Administração", @admins, "bg-teal-600"],
        ["Time T&I (Análise)", @analistas, "bg-blue-600"], ["FI Group", @fi, "bg-violet-600"]].each do |titulo, lista, cor| %>
      <div class="tsuru-card p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="w-2 h-2 rounded-full <%= cor %>"></span>
          <div class="text-[12px] font-semibold text-gray-900"><%= titulo %></div>
          <span class="ml-auto text-[10.5px] text-gray-400"><%= lista.size %></span>
        </div>
        <% if lista.any? %>
          <% lista.each { |u| %><%= pess.call(u) %><% } %>
        <% else %>
          <div class="text-[11.5px] text-gray-400 italic">ninguém</div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# === Áreas (superior -> equipe) === %>
  <div>
    <div class="subhead mb-2">Áreas operacionais</div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @por_area.each do |grupo| %>
        <div class="tsuru-card p-4">
          <div class="flex items-center justify-between">
            <div class="text-[13px] font-semibold text-gray-900"><%= grupo[:area] %></div>
            <span class="text-[10.5px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-600"><%= grupo[:demandas] %> demandas</span>
          </div>

          <%# Superior(es) da área %>
          <div class="mt-3">
            <div class="text-[10.5px] uppercase tracking-wider text-gray-400 font-medium mb-1">Superior</div>
            <% if grupo[:supervisores].any? %>
              <% grupo[:supervisores].each { |s| %>
                <div class="bg-amber-50/60 ring-1 ring-amber-100 rounded-md px-2 py-1"><%= pess.call(s) %></div>
              <% } %>
            <% else %>
              <div class="text-[11.5px] text-rose-600">⚠ sem superior definido</div>
            <% end %>
          </div>

          <%# Equipe vinculada %>
          <div class="mt-3 pl-3 border-l-2 border-gray-100">
            <div class="text-[10.5px] uppercase tracking-wider text-gray-400 font-medium mb-1">Equipe (<%= grupo[:equipe].size %>)</div>
            <% if grupo[:equipe].any? %>
              <% grupo[:equipe].each { |m| %><%= pess.call(m) %><% } %>
            <% else %>
              <div class="text-[11.5px] text-gray-400 italic">sem subordinados vinculados</div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# === Superiores sem área === %>
  <% if @sem_area.any? %>
    <div class="rounded-md p-3 bg-amber-50 ring-1 ring-amber-200">
      <div class="text-[12px] font-semibold text-amber-800 mb-1">Superiores sem área (não recebem demandas)</div>
      <div class="flex flex-wrap gap-3">
        <% @sem_area.each { |u| %><span class="text-[12px] text-amber-900"><%= u.display_name %></span><% } %>
      </div>
    </div>
  <% end %>
</div>
