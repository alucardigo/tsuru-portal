<% content_for :title, "Organograma" %>
<% content_for :nav_active, "usuarios" %>
<% content_for :crumb, "Administração" %>
<% content_for :subtitle, "· estrutura por área" %>
<% content_for :actions do %>
  <%= link_to admin_areas_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>Gerenciar áreas<% end %>
  <%= link_to admin_users_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>
    <%= icon(:user, size: 12) %> Usuários
  <% end %>
<% end %>

<div class="px-7 py-6 max-w-[1300px] mx-auto space-y-6">
  <%# Topo — Diretoria + squads transversais %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <% [
      ["Diretoria", @diretoria, "violet"],
      ["Time T&I (analistas)", @analistas, "blue"],
      ["FI Group (consultoria)", @fi, "teal"]
    ].each do |titulo, pessoas, cor| %>
      <div class="bg-white rounded-lg border border-gray-200 p-4">
        <div class="text-[10.5px] uppercase tracking-wider text-<%= cor %>-700 font-semibold mb-2"><%= titulo %></div>
        <% if pessoas.empty? %>
          <div class="text-[12px] text-gray-400 italic">—</div>
        <% else %>
          <div class="space-y-1.5">
            <% pessoas.each do |u| %>
              <div class="flex items-center gap-2 text-[12.5px]">
                <span class="w-6 h-6 rounded-full bg-<%= cor %>-100 text-<%= cor %>-700 text-[10px] font-semibold inline-flex items-center justify-center"><%= u.name.to_s[0,2].upcase %></span>
                <span class="text-gray-900 font-medium truncate"><%= u.display_name %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Árvore por área %>
  <div>
    <h2 class="text-[14px] font-semibold text-gray-900 mb-3">Áreas operacionais</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% @por_area.each do |bloco| %>
        <div class="bg-white rounded-lg border border-gray-200 p-4 flex flex-col">
          <div class="flex items-center gap-2 mb-3 pb-2 border-b border-gray-100">
            <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background: var(--accent)"></span>
            <h3 class="text-[13.5px] font-semibold text-gray-900 flex-1 truncate"><%= bloco[:area].name %></h3>
            <span class="text-[10.5px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-600" title="membros"><%= bloco[:total] %> 👤</span>
            <span class="text-[10.5px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-600" title="demandas"><%= bloco[:demandas] %> 📁</span>
          </div>

          <% if bloco[:supervisores].empty? && bloco[:outros].empty? %>
            <div class="text-[12px] text-gray-400 italic">Sem membros nesta área.</div>
          <% end %>

          <%# Gestores + equipe direta aninhada (estilo Teams) %>
          <% bloco[:supervisores].each do |sup| %>
            <div class="mb-2">
              <div class="flex items-center gap-2 text-[12.5px]">
                <span class="w-6 h-6 rounded-full text-white text-[10px] font-semibold inline-flex items-center justify-center shrink-0" style="background: var(--accent)"><%= sup.name.to_s[0,2].upcase %></span>
                <span class="font-semibold text-gray-900 truncate"><%= sup.display_name %></span>
                <span class="text-[9.5px] uppercase tracking-wider text-amber-600 font-bold shrink-0">superior</span>
              </div>
              <% equipe = bloco[:equipe_por_sup][sup.id] || [] %>
              <% if equipe.any? %>
                <div class="ml-3 mt-1 pl-3 border-l-2 border-gray-200 space-y-1">
                  <% equipe.each do |u| %>
                    <div class="flex items-center gap-2 text-[12px]">
                      <span class="w-5 h-5 rounded-full bg-gray-100 text-gray-600 text-[9px] font-semibold inline-flex items-center justify-center shrink-0"><%= u.name.to_s[0,2].upcase %></span>
                      <span class="text-gray-800 truncate"><%= u.display_name %></span>
                      <span class="text-[9.5px] text-gray-400 shrink-0"><%= role_label(u.role) %></span>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>

          <%# Membros da área sem vínculo direto de supervisor %>
          <% if bloco[:outros].any? %>
            <div class="mt-auto pt-2 <%= 'border-t border-gray-100' if bloco[:supervisores].any? %>">
              <div class="text-[10px] uppercase tracking-wider text-gray-400 font-medium mb-1">Membros</div>
              <div class="flex flex-wrap gap-1.5">
                <% bloco[:outros].each do |u| %>
                  <span class="inline-flex items-center gap-1 text-[11px] pl-0.5 pr-1.5 py-0.5 rounded-full bg-gray-50 border border-gray-200" title="<%= role_label(u.role) %>">
                    <span class="w-[18px] h-[18px] rounded-full bg-indigo-100 text-indigo-700 text-[8.5px] font-semibold inline-flex items-center justify-center"><%= u.name.to_s[0,2].upcase %></span>
                    <span class="text-gray-800"><%= u.display_name.truncate(22) %></span>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Sem área %>
  <% if @sem_area.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <div class="text-[11px] uppercase tracking-wider text-amber-700 font-semibold mb-2">Sem área definida (<%= @sem_area.size %>)</div>
      <div class="flex flex-wrap gap-1.5">
        <% @sem_area.each do |u| %>
          <span class="inline-flex items-center gap-1 text-[11.5px] px-2 py-0.5 rounded-full bg-white border border-amber-200 text-gray-800">
            <%= u.display_name %> <span class="text-[9.5px] text-gray-400"><%= role_label(u.role) %></span>
          </span>
        <% end %>
      </div>
      <div class="text-[11px] text-amber-700 mt-2">Atribua áreas em <%= link_to "Gerenciar áreas", admin_areas_path, class: "underline font-medium" %>.</div>
    </div>
  <% end %>
</div>
