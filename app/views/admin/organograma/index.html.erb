<% content_for :title, "Organograma" %>
<% content_for :nav_active, "usuarios" %>
<% content_for :crumb, "Administração" %>
<% content_for :subtitle, "· árvore hierárquica" %>
<% content_for :actions do %>
  <%= link_to admin_areas_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>Gerenciar áreas<% end %>
  <%= link_to admin_users_path, class: "tsuru-btn-ghost !h-7 !text-[11.5px] !px-2" do %>
    <%= icon(:user, size: 12) %> Usuários
  <% end %>
<% end %>

<div class="px-7 py-6 max-w-[1100px] mx-auto space-y-6">
  <%# Topo — Diretoria %>
  <div class="bg-white rounded-lg border border-gray-200 p-4">
    <div class="text-[10.5px] uppercase tracking-wider text-violet-700 font-semibold mb-2">Diretoria</div>
    <% if @diretoria.empty? %>
      <div class="text-[12px] text-gray-400 italic">—</div>
    <% else %>
      <div class="flex flex-wrap gap-3">
        <% @diretoria.each do |u| %>
          <div class="flex items-center gap-2 text-[12.5px] bg-violet-50 rounded-full pl-1 pr-3 py-1">
            <%= avatar(u, size: 24, color: "bg-violet-100 text-violet-700") %>
            <span class="text-gray-900 font-medium"><%= u.display_name %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Árvore genealógica — quem reporta pra quem, de verdade %>
  <div class="bg-white rounded-lg border border-gray-200 p-4">
    <div class="flex items-center justify-between mb-3">
      <div class="text-[10.5px] uppercase tracking-wider text-gray-500 font-semibold">Hierarquia (abaixo da Diretoria)</div>
      <span class="text-[10.5px] text-gray-400">linha vertical = reporta para</span>
    </div>
    <% if @nivel1.empty? %>
      <div class="text-[12px] text-gray-400 italic">Nenhuma liderança sem superior definido ainda.</div>
    <% else %>
      <div class="space-y-3">
        <% @nivel1.each do |lider| %>
          <%= render "org_node", user: lider, filhos_por_supervisor: @filhos_por_supervisor, level: 0 %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Squads transversais %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-[10.5px] uppercase tracking-wider text-blue-700 font-semibold mb-2">Time T&I (analistas)</div>
      <% if @analistas.empty? %>
        <div class="text-[12px] text-gray-400 italic">—</div>
      <% else %>
        <div class="space-y-1.5">
          <% @analistas.each do |u| %>
            <div class="flex items-center gap-2 text-[12.5px]">
              <%= avatar(u, size: 24, color: "bg-blue-100 text-blue-700") %>
              <span class="text-gray-900 font-medium truncate"><%= u.display_name %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-[10.5px] uppercase tracking-wider text-teal-700 font-semibold mb-2">FI Group (consultoria)</div>
      <% if @fi.empty? %>
        <div class="text-[12px] text-gray-400 italic">—</div>
      <% else %>
        <div class="space-y-1.5">
          <% @fi.each do |u| %>
            <div class="flex items-center gap-2 text-[12.5px]">
              <%= avatar(u, size: 24, color: "bg-teal-100 text-teal-700") %>
              <span class="text-gray-900 font-medium truncate"><%= u.display_name %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Sem hierarquia definida %>
  <% if @sem_hierarquia.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <div class="text-[11px] uppercase tracking-wider text-amber-700 font-semibold mb-2">
        Sem superior definido (<%= @sem_hierarquia.size %>)
      </div>
      <p class="text-[11.5px] text-amber-800 mb-2">
        Não aparecem na árvore acima porque ainda não têm um superior atribuído.
        Defina em <%= link_to "Usuários → coluna Superior", admin_users_path, class: "underline font-medium" %> pra encaixar na hierarquia.
      </p>
      <div class="flex flex-wrap gap-1.5 max-h-[220px] overflow-y-auto">
        <% @sem_hierarquia.each do |u| %>
          <span class="inline-flex items-center gap-1 text-[11.5px] px-2 py-0.5 rounded-full bg-white border border-amber-200 text-gray-800">
            <%= u.display_name %>
            <span class="text-[9.5px] text-gray-400"><%= role_label(u.role) %><%= " · #{u.area}" if u.area.present? %></span>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
