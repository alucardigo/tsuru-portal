<% content_for :title, @article.title %>
<% content_for :nav_active, "biblioteca" %>
<% content_for :crumb, "Biblioteca PD&I · #{KnowledgeArticle::CATEGORY_LABELS[@article.category]}" %>

<div class="max-w-[800px] mx-auto px-7 py-6">
  <%= link_to "← Voltar à biblioteca", biblioteca_path, class: "text-[12px] text-gray-500 hover:text-gray-900" %>
  <div class="bg-white rounded-lg border border-gray-200 p-6 mt-3">
    <%= pill(KnowledgeArticle::CATEGORY_LABELS[@article.category], color: "blue") %>
    <h1 class="text-[20px] font-semibold text-gray-900 mt-2 mb-4"><%= @article.title %></h1>
    <div class="text-[13.5px] text-gray-700 leading-relaxed whitespace-pre-line"><%= @article.body %></div>
  </div>
</div>
