<% content_for :title, "Sprints" %>
<% content_for :crumb, "Projeto #{@demand.codigo_display}" %>
<% content_for :subtitle, "· #{@demand.title.truncate(40)}" %>
<% content_for :actions do %>
  <%= link_to demand_path(@demand), class: "tsuru-btn-ghost" do %>← Projeto<% end %>
  <%= link_to new_demand_sprint_path(@demand), class: "tsuru-btn-primary" do %>+ Nova sprint<% end %>
<% end %>

<div class="px-7 py-6 max-w-[1400px] mx-auto space-y-6">
  <% if @active_sprint %>
    <section>
      <div class="flex items-center justify-between mb-3">
        <div>
          <div class="text-[10.5px] uppercase tracking-wider text-emerald-700 font-semibold">Sprint ativa</div>
          <h2 class="text-[16px] font-semibold text-gray-900"><%= @active_sprint.name %></h2>
          <div class="text-[12px] text-gray-500"><%= @active_sprint.start_date %> → <%= @active_sprint.end_date %> · Meta: <%= @active_sprint.goal.presence || "—" %></div>
        </div>
        <div class="flex items-center gap-3 text-[12px] text-gray-700">
          <div><span class="text-gray-500">Velocity:</span> <%= @active_sprint.velocity_points %>/<%= @active_sprint.total_points %> pts</div>
          <%= link_to "Ver board", demand_sprint_path(@demand, @active_sprint), class: "tsuru-btn-secondary !h-7 !text-[11.5px] !px-2.5" %>
        </div>
      </div>
    </section>
  <% end %>

  <section>
    <h3 class="text-[13px] font-semibold text-gray-900 mb-2">Todas as sprints (<%= @sprints.size %>)</h3>
    <% if @sprints.empty? %>
      <div class="tsuru-card p-8 text-center text-[13px] text-gray-500">
        Nenhuma sprint ainda. <%= link_to "Crie a primeira", new_demand_sprint_path(@demand), class: "text-indigo-700 hover:underline" %>.
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <table class="w-full text-[12.5px]">
          <thead class="bg-gray-50 text-[10.5px] uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-3 py-2 text-left">Sprint</th>
              <th class="px-3 py-2 text-left">Período</th>
              <th class="px-3 py-2 text-right">Pts</th>
              <th class="px-3 py-2 text-center">Estado</th>
              <th class="px-3 py-2 text-right">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @sprints.each do |s| %>
              <tr class="border-t border-gray-100 hover:bg-gray-50/60">
                <td class="px-3 py-2">
                  <%= link_to s.name, demand_sprint_path(@demand, s), class: "font-medium text-indigo-700 hover:underline" %>
                  <div class="text-[11px] text-gray-500 truncate max-w-md"><%= s.goal.presence || "—" %></div>
                </td>
                <td class="px-3 py-2 text-gray-700"><%= s.start_date %> → <%= s.end_date %></td>
                <td class="px-3 py-2 text-right tabular-nums text-gray-700"><%= s.velocity_points %>/<%= s.total_points %></td>
                <td class="px-3 py-2 text-center">
                  <% st_color = { "planejado" => "gray", "ativo" => "emerald", "concluido" => "violet" }[s.state] %>
                  <span class="text-[10.5px] px-2 py-0.5 rounded-full bg-<%= st_color %>-50 text-<%= st_color %>-700 font-medium"><%= s.state %></span>
                </td>
                <td class="px-3 py-2 text-right">
                  <% %w[planejado ativo concluido].each do |target| %>
                    <% next if target == s.state %>
                    <%= button_to target.capitalize, demand_sprint_path(@demand, s), method: :patch,
                          params: { sprint: { state: target } },
                          class: "tsuru-btn-ghost !h-7 !text-[11px] !px-2",
                          form: { class: "inline" } %>
                  <% end %>
                  <%= button_to "Remover", demand_sprint_path(@demand, s), method: :delete,
                        data: { turbo_confirm: "Remover sprint?" },
                        class: "tsuru-btn-ghost !h-7 !text-[11px] !px-2 !text-rose-600",
                        form: { class: "inline" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>

  <section>
    <h3 class="text-[13px] font-semibold text-gray-900 mb-2">Backlog (não alocado em sprint) — <%= @backlog.size %></h3>
    <% if @backlog.empty? %>
      <div class="tsuru-card p-6 text-center text-[12.5px] text-gray-500">Tudo alocado em alguma sprint.</div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
        <% @backlog.each do |t| %>
          <div class="px-3 py-2 flex items-center gap-3 text-[12.5px]">
            <span class="text-[10.5px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-700"><%= t.kanban_status_label %></span>
            <%= link_to t.title, edit_demand_task_path(@demand, t), class: "flex-1 truncate text-gray-900 hover:underline", data: { turbo_frame: "modal" } %>
            <% if t.story_points %>
              <span class="text-[11px] font-medium text-gray-700">SP <%= t.story_points %></span>
            <% end %>
            <% if @active_sprint %>
              <%= button_to "→ #{@active_sprint.name}", assign_task_demand_sprint_path(@demand, @active_sprint),
                    method: :post, params: { task_id: t.id },
                    class: "tsuru-btn-secondary !h-7 !text-[11px] !px-2",
                    form: { class: "inline" } %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
</div>

<%= turbo_frame_tag "modal" %>
