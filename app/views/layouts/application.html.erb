<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title).presence ? "#{content_for(:title)} · Tsuru" : "Tsuru · Portal de Inovação PD&I" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-role="<%= current_user&.role %>" class="min-h-screen">
    <% if user_signed_in? %>
      <div class="flex h-screen overflow-hidden">
        <%= render "shared/sidebar", user: current_user, active: yield(:nav_active).presence || "inicio" %>

        <div class="flex-1 flex flex-col min-w-0">
          <%= render "shared/topbar",
                crumb: yield(:crumb),
                title: yield(:title).presence || "Tsuru",
                subtitle: yield(:subtitle),
                actions: yield(:actions) %>

          <%= render "shared/flash" %>

          <main id="main-content" class="flex-1 overflow-auto">
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <%= render "shared/flash" %>
      <%= yield %>
    <% end %>
  </body>
</html>
