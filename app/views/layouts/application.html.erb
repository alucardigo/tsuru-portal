<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title).presence || "Tsuru — Portal de Inovação PD&I" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 font-sans text-gray-900 antialiased min-h-screen flex flex-col">

    <%# Navbar %>
    <header class="bg-primary-900 text-white shadow-md" data-controller="navbar">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">

        <%# Logo + nome %>
        <div class="flex items-center gap-3">
          <%= link_to root_path, class: "flex items-center gap-2 hover:opacity-90 transition-opacity" do %>
            <svg class="w-7 h-7 text-white" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20 4C20 4 8 14 8 24C8 31.732 13.268 37 20 37C26.732 37 32 31.732 32 24C32 14 20 4 20 4Z" fill="currentColor" opacity="0.9"/>
              <path d="M20 4C20 4 32 14 32 24" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
              <circle cx="20" cy="24" r="4" fill="white" opacity="0.8"/>
            </svg>
            <span class="text-lg font-semibold tracking-tight">Tsuru</span>
            <span class="hidden sm:inline text-primary-300 text-sm font-normal">Portal de Inovação</span>
          <% end %>
        </div>

        <%# Links de navegação %>
        <div class="flex items-center gap-6">
          <% if user_signed_in? %>
            <%= link_to "Minhas demandas", my_demands_path, class: "text-primary-200 hover:text-white text-sm font-medium transition-colors" rescue nil %>
            <%= link_to "Dashboard", dashboard_path, class: "text-primary-200 hover:text-white text-sm font-medium transition-colors" rescue nil if current_user.respond_to?(:director?) && current_user.director? rescue nil %>

            <%# Notificações (placeholder para Sprint 2) %>
            <button class="relative text-primary-200 hover:text-white transition-colors" aria-label="Notificações">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </button>

            <%# Avatar / menu do usuário %>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-primary-700 flex items-center justify-center text-sm font-semibold text-white select-none">
                <%= current_user.name.first.upcase rescue "U" %>
              </div>
              <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete },
                  class: "text-primary-200 hover:text-white text-sm transition-colors" rescue nil %>
            </div>
          <% else %>
            <%= link_to "Entrar", new_user_session_path, class: "tsuru-btn-secondary !text-white !border-primary-500 !bg-primary-700 hover:!bg-primary-600" rescue link_to("Entrar", "/users/sign_in", class: "text-primary-200 hover:text-white text-sm font-medium") %>
          <% end %>
        </div>

      </nav>
    </header>

    <%# Flash messages %>
    <% if notice || alert %>
      <div id="flash-messages" class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 mt-4" role="alert" aria-live="polite">
        <% if notice %>
          <div class="flex items-start gap-3 bg-success-100 border border-success-500 text-success-700 rounded-lg px-4 py-3 mb-2"
               data-controller="dismissable">
            <svg class="w-5 h-5 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <p class="text-sm font-medium"><%= notice %></p>
          </div>
        <% end %>
        <% if alert %>
          <div class="flex items-start gap-3 bg-danger-100 border border-danger-500 text-danger-700 rounded-lg px-4 py-3 mb-2"
               data-controller="dismissable">
            <svg class="w-5 h-5 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <p class="text-sm font-medium"><%= alert %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Conteúdo principal %>
    <main id="main-content" class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="bg-white border-t border-gray-200 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-sm text-gray-500">
          <svg class="w-4 h-4 text-primary-900" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20 4C20 4 8 14 8 24C8 31.732 13.268 37 20 37C26.732 37 32 31.732 32 24C32 14 20 4 20 4Z" fill="currentColor"/>
          </svg>
          <span>Tsuru Portal de Inovação PD&I &copy; <%= Date.current.year %></span>
        </div>
        <div class="flex items-center gap-4 text-xs text-gray-400">
          <span>Lei do Bem · Lei 11.196/2005 · Portaria MCTI 9.563/2025</span>
          <span class="hidden sm:inline">·</span>
          <span class="hidden sm:inline">Privacidade · LGPD</span>
        </div>
      </div>
    </footer>

  </body>
</html>
