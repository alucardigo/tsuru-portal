<% priority_class = {
  "baixa"   => "bg-gray-100 text-gray-700",
  "media"   => "bg-blue-100 text-blue-700",
  "alta"    => "bg-orange-100 text-orange-700",
  "urgente" => "bg-red-100 text-red-700"
}[task.priority] %>

<div class="bg-white rounded-lg border border-gray-200 hover:border-gray-300 hover:shadow-sm p-3 cursor-grab transition"
     data-task-id="<%= task.id %>"
     data-kanban-drag-target="card"
     draggable="true">
  <div class="flex items-start justify-between gap-2 mb-2">
    <span class="text-[11px] px-2 py-0.5 rounded-full font-medium <%= priority_class %>">
      <%= task.priority_label %>
    </span>
    <% if task.atrasada? %>
      <span class="text-[11px] px-2 py-0.5 rounded-full bg-red-50 text-red-700 font-medium">
        ⚠ <%= task.due_date.strftime("%d/%m") %>
      </span>
    <% elsif task.due_date.present? %>
      <span class="text-[11px] text-gray-500"><%= task.due_date.strftime("%d/%m") %></span>
    <% end %>
  </div>

  <%= link_to edit_demand_task_path(task.demand, task), class: "block text-[13px] font-medium text-gray-900 leading-snug mb-2",
        data: { turbo_frame: "modal" } do %>
    <%= task.title %>
  <% end %>

  <% if task.description.present? %>
    <div class="text-[12px] text-gray-500 mb-2 line-clamp-2"><%= task.description.to_s.truncate(80) %></div>
  <% end %>

  <div class="flex items-center justify-between text-[11px] text-gray-500">
    <div>
      <% if task.assignee %>
        <span class="inline-block w-5 h-5 rounded-full bg-indigo-100 text-indigo-700 text-center leading-5 font-semibold mr-1"><%= task.assignee.name.to_s[0, 2].upcase %></span>
        <%= task.assignee.name %>
      <% else %>
        <span class="text-gray-400 italic">sem responsável</span>
      <% end %>
    </div>
    <% if task.horas_resumo %>
      <span class="text-gray-600 font-medium"><%= task.horas_resumo %></span>
    <% end %>
  </div>

  <%# Mover via dropdown (fallback se drag-drop nao funcionar) %>
  <div class="flex items-center justify-between mt-2 pt-2 border-t border-gray-100">
    <%= form_with url: move_demand_task_path(task.demand, task), method: :patch, local: true, class: "inline-flex items-center gap-1" do |f| %>
      <%= f.select :kanban_status, ProjectTask::KANBAN_STATUSES.map { |s| [ProjectTask.new(kanban_status: s).kanban_status_label, s] }, { selected: task.kanban_status }, class: "text-[11px] border border-gray-200 rounded px-1 py-0.5", onchange: "this.form.requestSubmit()" %>
      <%= f.hidden_field :position, value: 0 %>
    <% end %>

    <%= button_to demand_task_path(task.demand, task), method: :delete,
          data: { turbo_confirm: "Excluir esta tarefa?" },
          class: "text-[11px] text-gray-400 hover:text-red-600" do %>✕<% end %>
  </div>
</div>
