<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black/40 z-40 flex items-start justify-center pt-10 pb-10 overflow-y-auto" data-controller="modal" data-action="click->modal#backdropClose">
    <div class="bg-white rounded-xl shadow-2xl max-w-2xl w-full p-6 mx-4 my-auto max-h-[88vh] overflow-y-auto" data-modal-target="dialog">
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="text-[12px] uppercase tracking-wider text-gray-400 font-medium">Tarefa do projeto</div>
          <h2 class="text-[20px] font-semibold text-gray-900">
            <%= task.new_record? ? "Nova tarefa" : "Editar tarefa" %>
          </h2>
        </div>
        <%= link_to kanban_demand_tasks_path(@demand), class: "text-gray-400 hover:text-gray-700 text-2xl leading-none" do %>×<% end %>
      </div>

      <%= form_with model: [@demand, task], url: task.new_record? ? demand_tasks_path(@demand) : demand_task_path(@demand, task),
              data: { turbo: false }, class: "space-y-4" do |f| %>

        <% if task.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-3 text-[13px] text-red-700">
            <% task.errors.full_messages.each do |msg| %>
              <div>• <%= msg %></div>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :title, "Título", class: "tsuru-label" %>
          <%= f.text_field :title, class: "tsuru-input mt-1", required: true, placeholder: "Ex: Implementar API de cotação Megleo" %>
        </div>

        <div>
          <%= f.label :description, "Descrição", class: "tsuru-label" %>
          <%= f.text_area :description, class: "tsuru-input mt-1", rows: 3, placeholder: "Contexto, requisitos, critérios de aceite…" %>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :kanban_status, "Coluna do kanban", class: "tsuru-label" %>
            <%= f.select :kanban_status,
                ProjectTask::KANBAN_STATUSES.map { |s| [ProjectTask.new(kanban_status: s).kanban_status_label, s] },
                {}, class: "tsuru-select mt-1" %>
          </div>
          <div>
            <%= f.label :priority, "Prioridade", class: "tsuru-label" %>
            <%= f.select :priority,
                ProjectTask::PRIORITIES.map { |p| [ProjectTask.new(priority: p).priority_label, p] },
                {}, class: "tsuru-select mt-1" %>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div>
            <%= f.label :estimated_hours, "Estimativa (horas)", class: "tsuru-label" %>
            <%= f.number_field :estimated_hours, step: 0.5, min: 0, class: "tsuru-input mt-1", placeholder: "8.0" %>
          </div>
          <div>
            <%= f.label :spent_hours, "Horas gastas", class: "tsuru-label" %>
            <%= f.number_field :spent_hours, step: 0.5, min: 0, class: "tsuru-input mt-1", placeholder: "0.0" %>
          </div>
          <div>
            <%= f.label :due_date, "Prazo", class: "tsuru-label" %>
            <%= f.date_field :due_date, class: "tsuru-input mt-1" %>
          </div>
        </div>

        <div>
          <%= f.label :assignee_id, "Responsável", class: "tsuru-label" %>
          <%= f.collection_select :assignee_id, User.order(:name), :id, :name,
                { include_blank: "— sem responsável —" }, class: "tsuru-select mt-1" %>
        </div>

        <% unless task.new_record? %>
          <%# Sprint 18 — Subtarefa de outra tarefa? %>
          <div>
            <%= f.label :parent_id, "Subtarefa de (opcional)", class: "tsuru-label" %>
            <%= f.collection_select :parent_id,
                  @demand.tasks.where.not(id: task.id).order(:title), :id, :title,
                  { include_blank: "— tarefa raiz —", selected: task.parent_id }, class: "tsuru-select mt-1" %>
          </div>
        <% end %>

        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
          <%= link_to "Cancelar", kanban_demand_tasks_path(@demand), class: "tsuru-btn-ghost" %>
          <%= f.submit (task.new_record? ? "Criar tarefa" : "Salvar"), class: "tsuru-btn-primary" %>
        </div>
      <% end %>

      <% unless task.new_record? %>
        <%# Sprint 18 — Checklist %>
        <section class="mt-6 pt-5 border-t border-gray-100">
          <h3 class="text-[13px] font-semibold text-gray-900 mb-2">
            Checklist
            <% if pct = task.checklist_progress %>
              <span class="text-[11px] text-gray-500 font-normal">· <%= pct %>% concluído</span>
            <% end %>
          </h3>
          <div class="space-y-1.5">
            <% task.checklist_items.ordered.each do |item| %>
              <div class="flex items-center gap-2 text-[12.5px]">
                <%= button_to toggle_demand_task_checklist_item_path(@demand, task, item), method: :patch,
                      class: "w-4 h-4 inline-flex items-center justify-center rounded border #{item.done ? 'bg-emerald-500 border-emerald-500 text-white' : 'border-gray-300 text-transparent'}",
                      form: { class: "inline" } do %>✓<% end %>
                <span class="flex-1 <%= 'line-through text-gray-400' if item.done %>"><%= item.title %></span>
                <%= button_to demand_task_checklist_item_path(@demand, task, item), method: :delete,
                      class: "text-[11px] text-gray-400 hover:text-rose-600",
                      data: { turbo_confirm: "Remover item?" },
                      form: { class: "inline" } do %>×<% end %>
              </div>
            <% end %>
          </div>
          <%= form_with url: demand_task_checklist_items_path(@demand, task), method: :post, class: "flex gap-2 mt-2", data: { turbo: false } do %>
            <input name="title" placeholder="Novo item da checklist…" class="tsuru-input flex-1 !h-8 !text-[12px]">
            <button class="tsuru-btn-secondary !h-8 !text-[12px]">Adicionar</button>
          <% end %>
        </section>

        <%# Sprint 18 — Dependências %>
        <section class="mt-5 pt-5 border-t border-gray-100">
          <h3 class="text-[13px] font-semibold text-gray-900 mb-2">
            Dependências
            <% if task.blocked? %>
              <span class="ml-2 text-[10.5px] px-2 py-0.5 rounded-full bg-rose-50 text-rose-700 font-medium">BLOQUEADA</span>
            <% end %>
          </h3>
          <% blocked_by = task.blocked_by %>
          <% if blocked_by.any? %>
            <div class="text-[11.5px] text-rose-700 mb-2">Aguardando concluir: <%= blocked_by.map(&:title).join(", ") %></div>
          <% end %>
          <% deps = task.dependencies_as_successor.includes(:predecessor) %>
          <div class="space-y-1">
            <% deps.each do |dep| %>
              <div class="flex items-center gap-2 text-[12px]">
                <span class="text-gray-500">após</span>
                <span class="font-medium text-gray-900"><%= dep.predecessor.title %></span>
                <span class="ml-auto text-[10.5px] px-1.5 py-0.5 rounded <%= dep.predecessor.kanban_status == 'concluida' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>"><%= dep.predecessor.kanban_status_label %></span>
                <%= button_to demand_task_dependency_path(@demand, task, dep), method: :delete,
                      class: "text-[11px] text-gray-400 hover:text-rose-600",
                      form: { class: "inline" } do %>×<% end %>
              </div>
            <% end %>
          </div>
          <%= form_with url: demand_task_dependencies_path(@demand, task), method: :post, class: "flex gap-2 mt-2", data: { turbo: false } do %>
            <%= select_tag :predecessor_id,
                  options_from_collection_for_select(@demand.tasks.where.not(id: task.id).order(:title), :id, :title),
                  include_blank: "— selecione predecessora —", class: "tsuru-select flex-1 !h-8 !text-[12px]" %>
            <button class="tsuru-btn-secondary !h-8 !text-[12px]">+ Dependência</button>
          <% end %>
        </section>

        <%# Sprint 18 — Subtarefas %>
        <% subs = task.subtasks.order(:position, :id) %>
        <% if subs.any? %>
          <section class="mt-5 pt-5 border-t border-gray-100">
            <h3 class="text-[13px] font-semibold text-gray-900 mb-2">Subtarefas (<%= subs.size %>)</h3>
            <div class="space-y-1">
              <% subs.each do |sub| %>
                <%= link_to edit_demand_task_path(@demand, sub), class: "flex items-center gap-2 text-[12px] hover:bg-gray-50 px-1 py-0.5 rounded", data: { turbo_frame: "modal" } do %>
                  <span class="text-[10.5px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-700"><%= sub.kanban_status_label %></span>
                  <span class="flex-1 truncate"><%= sub.title %></span>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
