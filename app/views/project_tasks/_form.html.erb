<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black/40 z-40 flex items-start justify-center pt-10 pb-10 overflow-y-auto" data-controller="modal" data-action="click->modal#backdropClose">
    <div class="bg-white rounded-xl shadow-2xl max-w-2xl w-full p-6 mx-4 my-auto max-h-[88vh] overflow-y-auto" data-modal-target="dialog">
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="text-[12px] uppercase tracking-wider text-gray-400 font-medium">Tarefa do projeto</div>
          <h2 class="text-[20px] font-semibold text-gray-900">
            <%= task.new_record? ? "Nova tarefa" : "Editar tarefa" %>
          </h2>
        </div>
        <%= link_to kanban_demand_tasks_path(@demand), class: "text-gray-400 hover:text-gray-700 text-2xl leading-none" do %>×<% end %>
      </div>

      <% if !task.new_record? && task.origin_demand.present? %>
        <div class="mb-4 -mt-2 text-[11.5px] text-indigo-700 bg-indigo-50 border border-indigo-100 rounded-md px-2.5 py-1.5">
          ↩️ Originada da sugestão <%= link_to task.origin_demand.codigo_display, demand_path(task.origin_demand), class: "underline font-medium" %>
        </div>
      <% end %>

      <% unless task.new_record? %>
        <%# Sprint 24 — barra de colaboração: Watch + Transferir %>
        <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-100 text-[12px]">
          <% is_watching = task.watchers.exists?(id: current_user.id) %>
          <% if is_watching %>
            <%= button_to demand_task_watcher_path(@demand, task), method: :delete,
                  class: "inline-flex items-center gap-1 px-2 py-1 rounded bg-indigo-50 text-indigo-700 hover:bg-indigo-100 font-medium",
                  form: { class: "inline" } do %>👁 Seguindo<% end %>
          <% else %>
            <%= button_to demand_task_watcher_path(@demand, task), method: :post,
                  class: "inline-flex items-center gap-1 px-2 py-1 rounded bg-gray-50 text-gray-700 hover:bg-gray-100 font-medium",
                  form: { class: "inline" } do %>👁 Seguir<% end %>
          <% end %>
          <span class="text-gray-500"><%= task.watchers.count %> seguindo</span>
          <% if task.watchers.any? %>
            <span class="flex -space-x-1 ml-1">
              <% task.watchers.limit(5).each do |w| %>
                <span title="<%= w.display_name %>" class="w-5 h-5 rounded-full bg-indigo-100 text-indigo-700 text-[9px] font-semibold flex items-center justify-center border border-white"><%= w.name.to_s[0,2].upcase %></span>
              <% end %>
            </span>
          <% end %>

          <details class="ml-auto relative">
            <summary class="inline-flex items-center gap-1 px-2 py-1 rounded bg-amber-50 text-amber-700 hover:bg-amber-100 font-medium cursor-pointer list-none">🔁 Transferir</summary>
            <div class="absolute right-0 mt-1 w-72 bg-white rounded-lg shadow-xl border border-gray-200 p-3 z-50">
              <%= form_with url: reassign_demand_task_path(@demand, task), method: :post, data: { turbo: false }, class: "space-y-2" do %>
                <div>
                  <label class="tsuru-label">Novo responsável</label>
                  <%= select_tag :assignee_id,
                        options_from_collection_for_select(User.ativos.order(:name), :id, :display_name),
                        include_blank: "— selecione —", class: "tsuru-select !text-[12px] w-full mt-1" %>
                </div>
                <div>
                  <label class="tsuru-label">Handoff note (opcional)</label>
                  <%= text_area_tag :handoff_note, "", rows: 2, class: "tsuru-input !text-[12px] w-full mt-1", placeholder: "Contexto rápido pro próximo dono…" %>
                </div>
                <button class="tsuru-btn-primary w-full !text-[12px]">Transferir</button>
              <% end %>
            </div>
          </details>
        </div>
      <% end %>

      <%= form_with model: [@demand, task], url: task.new_record? ? demand_tasks_path(@demand) : demand_task_path(@demand, task),
              data: { turbo: false }, html: { multipart: true }, class: "space-y-4" do |f| %>

        <% if task.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-3 text-[13px] text-red-700">
            <% task.errors.full_messages.each do |msg| %>
              <div>• <%= msg %></div>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :title, "Título", class: "tsuru-label" %>
          <%= f.text_field :title, class: "tsuru-input mt-1", required: true, placeholder: "Ex: Implementar API de cotação Megleo" %>
        </div>

        <div>
          <%= f.label :description, "Descrição", class: "tsuru-label" %>
          <%= f.text_area :description, class: "tsuru-input mt-1", rows: 3, placeholder: "Contexto, requisitos, critérios de aceite…" %>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :kanban_status, "Coluna do kanban", class: "tsuru-label" %>
            <%= f.select :kanban_status,
                ProjectTask::KANBAN_STATUSES.map { |s| [ProjectTask.new(kanban_status: s).kanban_status_label, s] },
                {}, class: "tsuru-select mt-1" %>
          </div>
          <div>
            <%= f.label :priority, "Prioridade", class: "tsuru-label" %>
            <%= f.select :priority,
                ProjectTask::PRIORITIES.map { |p| [ProjectTask.new(priority: p).priority_label, p] },
                {}, class: "tsuru-select mt-1" %>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <div>
            <%= f.label :estimated_hours, "Estimativa (h)", class: "tsuru-label" %>
            <%= f.number_field :estimated_hours, step: 0.5, min: 0, class: "tsuru-input mt-1", placeholder: "8.0" %>
          </div>
          <div>
            <%= f.label :spent_hours, "Gastas (h)", class: "tsuru-label" %>
            <%= f.number_field :spent_hours, step: 0.5, min: 0, class: "tsuru-input mt-1", placeholder: "0.0" %>
          </div>
          <div>
            <%= f.label :story_points, "Story points", class: "tsuru-label" %>
            <%= f.number_field :story_points, step: 1, min: 0, class: "tsuru-input mt-1", placeholder: "5" %>
          </div>
          <div>
            <%= f.label :due_date, "Prazo", class: "tsuru-label" %>
            <%= f.date_field :due_date, class: "tsuru-input mt-1" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <%= f.label :assignee_id, "Responsável", class: "tsuru-label" %>
            <%= f.collection_select :assignee_id, User.order(:name), :id, :name,
                  { include_blank: "— sem responsável —" }, class: "tsuru-select mt-1" %>
          </div>
          <div>
            <label class="tsuru-label">Recorrência</label>
            <% rec_kind = (task.recurrence || {})["kind"] %>
            <select name="project_task[recurrence_kind]" class="tsuru-select mt-1">
              <option value="" <%= "selected" if rec_kind.blank? %>>Sem recorrência</option>
              <option value="daily"   <%= "selected" if rec_kind == "daily" %>>Diária</option>
              <option value="weekly"  <%= "selected" if rec_kind == "weekly" %>>Semanal</option>
              <option value="monthly" <%= "selected" if rec_kind == "monthly" %>>Mensal (30d)</option>
            </select>
            <% if task.recurrence.present? %>
              <p class="text-[10.5px] text-gray-500 mt-1">Próxima ocorrência: <%= task.recurrence["next_at"] %></p>
            <% end %>
          </div>
        </div>

        <div>
          <label class="tsuru-label">Corresponsáveis (colaboram junto com o responsável)</label>
          <input type="hidden" name="project_task[additional_assignee_ids][]" value="">
          <%= select_tag "project_task[additional_assignee_ids][]",
                options_from_collection_for_select(User.ativos.order(:name), :id, :display_name,
                                                   task.task_assignees.pluck(:user_id)),
                multiple: true, size: 4, class: "tsuru-select mt-1 !h-auto" %>
          <p class="text-[10.5px] text-gray-400 mt-1">Segure Ctrl (ou Cmd) para selecionar vários.</p>
        </div>

        <% unless task.new_record? %>
          <%# Sprint 18 — Subtarefa de outra tarefa? %>
          <div>
            <%= f.label :parent_id, "Subtarefa de (opcional)", class: "tsuru-label" %>
            <%= f.collection_select :parent_id,
                  @demand.tasks.where.not(id: task.id).order(:title), :id, :title,
                  { include_blank: "— tarefa raiz —", selected: task.parent_id }, class: "tsuru-select mt-1" %>
          </div>
        <% end %>

        <%# Custom fields (Sprint 25 — definidos por demand) %>
        <% defs = @demand.task_field_definitions || [] %>
        <% if defs.any? %>
          <div class="pt-3 border-t border-gray-100">
            <div class="text-[10.5px] uppercase tracking-wider text-gray-400 font-medium mb-2">Campos personalizados</div>
            <div class="space-y-2">
              <% defs.each do |d| %>
                <% key = d["key"]; label = d["label"]; kind = d["kind"]; val = (task.custom_fields || {})[key] %>
                <div>
                  <label class="tsuru-label" for="cf_<%= key %>"><%= label %></label>
                  <% case kind %>
                  <% when "text" %>
                    <input type="text" name="project_task[custom_fields][<%= key %>]" value="<%= val %>" id="cf_<%= key %>" class="tsuru-input mt-1"/>
                  <% when "url" %>
                    <input type="url" name="project_task[custom_fields][<%= key %>]" value="<%= val %>" id="cf_<%= key %>" placeholder="https://…" class="tsuru-input mt-1"/>
                  <% when "number" %>
                    <input type="number" step="any" name="project_task[custom_fields][<%= key %>]" value="<%= val %>" id="cf_<%= key %>" class="tsuru-input mt-1"/>
                  <% when "date" %>
                    <input type="date" name="project_task[custom_fields][<%= key %>]" value="<%= val %>" id="cf_<%= key %>" class="tsuru-input mt-1"/>
                  <% when "select" %>
                    <select name="project_task[custom_fields][<%= key %>]" id="cf_<%= key %>" class="tsuru-select mt-1">
                      <option value="">—</option>
                      <% (d["options"] || []).each do |opt| %>
                        <option value="<%= opt %>" <%= "selected" if val == opt %>><%= opt %></option>
                      <% end %>
                    </select>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Upload de anexos (precisa estar dentro do form principal — multipart) %>
        <div>
          <%= f.label :attachments, "Adicionar arquivos (anexar ao salvar)", class: "tsuru-label" %>
          <%= f.file_field :attachments, multiple: true, class: "tsuru-input mt-1 !p-1.5 !text-[12px]" %>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
          <%= link_to "Cancelar", kanban_demand_tasks_path(@demand), class: "tsuru-btn-ghost" %>
          <%= f.submit (task.new_record? ? "Criar tarefa" : "Salvar"), class: "tsuru-btn-primary" %>
        </div>
      <% end %>

      <% unless task.new_record? %>
        <%# Sprint 18 — Checklist %>
        <section class="mt-6 pt-5 border-t border-gray-100">
          <h3 class="text-[13px] font-semibold text-gray-900 mb-2">
            Checklist
            <% if pct = task.checklist_progress %>
              <span class="text-[11px] text-gray-500 font-normal">· <%= pct %>% concluído</span>
            <% end %>
          </h3>
          <div class="space-y-1.5">
            <% task.checklist_items.ordered.each do |item| %>
              <div class="flex items-center gap-2 text-[12.5px]">
                <%= button_to toggle_demand_task_checklist_item_path(@demand, task, item), method: :patch,
                      class: "w-4 h-4 inline-flex items-center justify-center rounded border #{item.done ? 'bg-emerald-500 border-emerald-500 text-white' : 'border-gray-300 text-transparent'}",
                      form: { class: "inline" } do %>✓<% end %>
                <span class="flex-1 <%= 'line-through text-gray-400' if item.done %>"><%= item.title %></span>
                <%= button_to demand_task_checklist_item_path(@demand, task, item), method: :delete,
                      class: "text-[11px] text-gray-400 hover:text-rose-600",
                      data: { turbo_confirm: "Remover item?" },
                      form: { class: "inline" } do %>×<% end %>
              </div>
            <% end %>
          </div>
          <%= form_with url: demand_task_checklist_items_path(@demand, task), method: :post, class: "flex gap-2 mt-2", data: { turbo: false } do %>
            <input name="title" placeholder="Novo item da checklist…" class="tsuru-input flex-1 !h-8 !text-[12px]">
            <button class="tsuru-btn-secondary !h-8 !text-[12px]">Adicionar</button>
          <% end %>
        </section>

        <%# Sprint 18 — Dependências %>
        <section class="mt-5 pt-5 border-t border-gray-100">
          <h3 class="text-[13px] font-semibold text-gray-900 mb-2">
            Dependências
            <% if task.blocked? %>
              <span class="ml-2 text-[10.5px] px-2 py-0.5 rounded-full bg-rose-50 text-rose-700 font-medium">BLOQUEADA</span>
            <% end %>
          </h3>
          <% blocked_by = task.blocked_by %>
          <% if blocked_by.any? %>
            <div class="text-[11.5px] text-rose-700 mb-2">Aguardando concluir: <%= blocked_by.map(&:title).join(", ") %></div>
          <% end %>
          <% deps = task.dependencies_as_successor.includes(:predecessor) %>
          <div class="space-y-1">
            <% deps.each do |dep| %>
              <div class="flex items-center gap-2 text-[12px]">
                <span class="text-gray-500">após</span>
                <span class="font-medium text-gray-900"><%= dep.predecessor.title %></span>
                <span class="ml-auto text-[10.5px] px-1.5 py-0.5 rounded <%= dep.predecessor.kanban_status == 'concluida' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>"><%= dep.predecessor.kanban_status_label %></span>
                <%= button_to demand_task_dependency_path(@demand, task, dep), method: :delete,
                      class: "text-[11px] text-gray-400 hover:text-rose-600",
                      form: { class: "inline" } do %>×<% end %>
              </div>
            <% end %>
          </div>
          <%= form_with url: demand_task_dependencies_path(@demand, task), method: :post, class: "flex gap-2 mt-2", data: { turbo: false } do %>
            <%= select_tag :predecessor_id,
                  options_from_collection_for_select(@demand.tasks.where.not(id: task.id).order(:title), :id, :title),
                  include_blank: "— selecione predecessora —", class: "tsuru-select flex-1 !h-8 !text-[12px]" %>
            <button class="tsuru-btn-secondary !h-8 !text-[12px]">+ Dependência</button>
          <% end %>
        </section>

        <%# Sprint 18 — Subtarefas %>
        <% subs = task.subtasks.order(:position, :id) %>
        <% if subs.any? %>
          <section class="mt-5 pt-5 border-t border-gray-100">
            <h3 class="text-[13px] font-semibold text-gray-900 mb-2">Subtarefas (<%= subs.size %>)</h3>
            <div class="space-y-1">
              <% subs.each do |sub| %>
                <%= link_to edit_demand_task_path(@demand, sub), class: "flex items-center gap-2 text-[12px] hover:bg-gray-50 px-1 py-0.5 rounded", data: { turbo_frame: "modal" } do %>
                  <span class="text-[10.5px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-700"><%= sub.kanban_status_label %></span>
                  <span class="flex-1 truncate"><%= sub.title %></span>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>

        <%# Anexos — has_many_attached. Upload está dentro do form principal acima. %>
        <% if task.attachments.attached? %>
          <section class="mt-5 pt-5 border-t border-gray-100">
            <h3 class="text-[13px] font-semibold text-gray-900 mb-2">
              Anexos
              <span class="text-[11px] text-gray-500 font-normal">· <%= task.attachments.size %></span>
            </h3>
            <div class="space-y-1">
              <% task.attachments.each do |att| %>
                <div class="flex items-center gap-2 text-[12px] py-1 px-1.5 rounded hover:bg-gray-50">
                  <span class="text-gray-400">📎</span>
                  <%= link_to att.filename.to_s, rails_blob_path(att, disposition: "attachment"), class: "flex-1 truncate text-indigo-700 hover:underline", target: "_blank", rel: "noopener" %>
                  <span class="text-[10.5px] text-gray-400 tabular-nums"><%= number_to_human_size(att.byte_size) %></span>
                  <%= button_to demand_task_attachment_path(@demand, task, att.id), method: :delete,
                        class: "text-[11px] text-gray-400 hover:text-rose-600",
                        data: { turbo_confirm: "Remover anexo #{att.filename}?" },
                        form: { class: "inline" } do %>×<% end %>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <%# Comentários — modelo próprio ProjectTaskComment %>
        <section class="mt-5 pt-5 border-t border-gray-100">
          <% comments = task.comments.includes(:user).recent %>
          <h3 class="text-[13px] font-semibold text-gray-900 mb-2">
            Comentários
            <span class="text-[11px] text-gray-500 font-normal">· <%= comments.size %></span>
          </h3>
          <% if comments.any? %>
            <div class="space-y-3 mb-3">
              <% comments.each do |c| %>
                <% grouped = c.reactions_grouped %>
                <div class="flex items-start gap-2 text-[12.5px]">
                  <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-[10px] font-semibold flex items-center justify-center shrink-0"><%= c.user.name.to_s[0,2].upcase %></div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-2">
                      <span class="text-[12px] font-medium text-gray-900"><%= c.user.display_name %></span>
                      <span class="text-[10.5px] text-gray-500"><%= c.created_at.strftime("%d/%m %H:%M") %></span>
                      <% if c.user_id == current_user.id || current_user.admin? %>
                        <%= button_to demand_task_comment_path(@demand, task, c), method: :delete,
                              class: "ml-auto text-[10.5px] text-gray-400 hover:text-rose-600",
                              data: { turbo_confirm: "Remover comentário?" },
                              form: { class: "inline" } do %>×<% end %>
                      <% end %>
                    </div>
                    <div class="text-[12.5px] text-gray-700 whitespace-pre-wrap"><%= c.body %></div>
                    <%# Reactions: bar com emojis disponíveis + counts %>
                    <div class="flex items-center flex-wrap gap-1 mt-1.5">
                      <% grouped.each do |emoji, users| %>
                        <% mine = users.any? { |u| u.id == current_user.id } %>
                        <%= button_to toggle_reaction_demand_task_comment_path(@demand, task, c, emoji: emoji), method: :post,
                              class: "inline-flex items-center gap-1 text-[11px] px-1.5 py-0.5 rounded #{mine ? 'bg-indigo-50 ring-1 ring-indigo-300 text-indigo-700' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}",
                              form: { class: "inline" },
                              title: users.map(&:display_name).join(", ") do %>
                          <span><%= emoji %></span>
                          <span class="tabular-nums"><%= users.size %></span>
                        <% end %>
                      <% end %>
                      <details class="relative">
                        <summary class="inline-flex items-center text-[11px] px-1.5 py-0.5 rounded text-gray-400 hover:bg-gray-100 cursor-pointer list-none">+ 😀</summary>
                        <div class="absolute left-0 mt-1 bg-white rounded-lg shadow-xl border border-gray-200 p-1.5 z-40 flex gap-0.5">
                          <% ProjectTaskCommentReaction::EMOJIS.each do |e| %>
                            <%= button_to toggle_reaction_demand_task_comment_path(@demand, task, c, emoji: e), method: :post,
                                  class: "text-[14px] px-1.5 py-0.5 rounded hover:bg-gray-100",
                                  form: { class: "inline" } do %><%= e %><% end %>
                          <% end %>
                        </div>
                      </details>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
          <%= form_with url: demand_task_comments_path(@demand, task), method: :post, scope: :project_task_comment, data: { turbo: false }, class: "flex flex-col gap-1.5" do |cf| %>
            <%= cf.text_area :body, class: "tsuru-input !text-[12.5px]", rows: 2, placeholder: "Comentário sobre esta tarefa…", required: true %>
            <div class="flex justify-end">
              <%= cf.submit "Comentar", class: "tsuru-btn-secondary !h-8 !text-[12px]" %>
            </div>
          <% end %>
        </section>

        <%# Activity feed — PaperTrail decifrado em português %>
        <section class="mt-5 pt-5 border-t border-gray-100">
          <% versions = task.versions.includes(:item).reorder(created_at: :desc).limit(20) %>
          <h3 class="text-[13px] font-semibold text-gray-900 mb-2">
            Atividade
            <span class="text-[11px] text-gray-500 font-normal">· últimas <%= versions.size %></span>
          </h3>
          <% if versions.any? %>
            <ol class="relative border-l border-gray-200 ml-1.5 space-y-2">
              <% versions.each do |v| %>
                <% who = User.find_by(id: v.whodunnit)&.display_name || "Sistema" %>
                <% changes = v.object_changes.is_a?(Hash) ? v.object_changes.reject { |k, _| %w[updated_at created_at lock_version assigned_at].include?(k) } : {} %>
                <%
                  label_for = ->(field) {
                    {
                      "kanban_status" => "status",
                      "priority"      => "prioridade",
                      "assignee_id"   => "responsável",
                      "title"         => "título",
                      "description"   => "descrição",
                      "due_date"      => "prazo",
                      "estimated_hours" => "estimativa (h)",
                      "spent_hours"   => "gastas (h)",
                      "story_points"  => "story points",
                      "parent_id"     => "tarefa pai",
                      "sprint_id"     => "sprint"
                    }[field] || field
                  }
                  pretty_val = ->(field, val) {
                    case field
                    when "assignee_id" then val.present? ? (User.find_by(id: val)&.display_name || "—") : "ninguém"
                    when "kanban_status" then ProjectTask.new(kanban_status: val).kanban_status_label rescue val
                    when "priority"      then ProjectTask.new(priority: val).priority_label rescue val
                    else val.is_a?(String) && val.length > 40 ? val.truncate(40) : val.inspect
                    end
                  }
                %>
                <li class="ml-3">
                  <span class="absolute -left-1.5 w-3 h-3 rounded-full <%= { 'create' => 'bg-emerald-500', 'update' => 'bg-blue-500', 'destroy' => 'bg-rose-500' }[v.event] || 'bg-gray-400' %>"></span>
                  <div class="text-[11.5px] text-gray-800">
                    <% if v.event == "create" %>
                      <strong><%= who %></strong> criou a tarefa
                    <% elsif v.event == "destroy" %>
                      <strong><%= who %></strong> excluiu a tarefa
                    <% elsif changes.any? %>
                      <strong><%= who %></strong>
                      <% if changes.size == 1 %>
                        alterou <%= label_for.call(changes.keys.first) %> de
                        <code class="text-[11px] bg-gray-100 px-1 rounded"><%= pretty_val.call(changes.keys.first, changes.values.first[0]) %></code>
                        para
                        <code class="text-[11px] bg-emerald-50 text-emerald-800 px-1 rounded"><%= pretty_val.call(changes.keys.first, changes.values.first[1]) %></code>
                      <% else %>
                        alterou <%= changes.keys.map { |f| label_for.call(f) }.first(4).join(", ") %>
                      <% end %>
                    <% else %>
                      <strong><%= who %></strong> tocou a tarefa
                    <% end %>
                  </div>
                  <div class="text-[10.5px] text-gray-400 tabular-nums"><%= v.created_at.strftime("%d/%m %H:%M") %></div>
                </li>
              <% end %>
            </ol>
          <% else %>
            <div class="text-[12px] text-gray-400 italic">Sem alterações registradas ainda.</div>
          <% end %>
        </section>
      <% end %>
    </div>
  </div>
<% end %>
