<div class="max-w-5xl mx-auto">
  <h1 class="text-2xl font-bold text-primary-900 mb-6">Dashboard</h1>

  <%# Estatísticas %>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <% stat_labels = { total: "Total", rascunho: "Rascunhos", submetidas: "Submetidas",
                       em_triagem: "Em triagem", aprovadas: "N1 Aprovadas", elegiveis: "Elegíveis" } %>
    <% @stats.each do |key, count| %>
      <div class="tsuru-card text-center">
        <p class="text-2xl font-bold text-primary-800"><%= count %></p>
        <p class="text-xs text-gray-500 mt-1"><%= stat_labels[key] %></p>
      </div>
    <% end %>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <%# Demandas recentes %>
    <div>
      <h2 class="text-lg font-semibold text-primary-900 mb-3">
        <%= current_user.colaborador? ? "Minhas demandas" : "Demandas recentes" %>
      </h2>
      <% if @recent_demands.empty? %>
        <div class="tsuru-card text-center py-8 text-gray-400 text-sm">Nenhuma demanda.</div>
      <% else %>
        <div class="space-y-2">
          <% @recent_demands.each do |d| %>
            <div class="tsuru-card flex items-center justify-between py-3">
              <div>
                <%= link_to d.title, demand_path(d), class: "font-medium text-primary-800 hover:underline text-sm" %>
                <p class="text-xs text-gray-400 mt-0.5"><%= d.user.display_name %></p>
              </div>
              <span class="tsuru-badge-<%= d.aasm_state %> text-xs"><%= d.aasm_state.humanize %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Fila de triagem (gestores) %>
    <% if current_user.gestor_or_above? && @pending_triagem&.any? %>
      <div>
        <h2 class="text-lg font-semibold text-primary-900 mb-3">Aguardando triagem N1</h2>
        <div class="space-y-2">
          <% @pending_triagem.each do |d| %>
            <div class="tsuru-card flex items-center justify-between py-3 border-l-4 border-accent-400">
              <div>
                <%= link_to d.title, demand_path(d), class: "font-medium text-primary-800 hover:underline text-sm" %>
                <p class="text-xs text-gray-400 mt-0.5">por <%= d.user.display_name %></p>
              </div>
              <%= button_to "Iniciar triagem", iniciar_triagem_demand_path(d), method: :patch,
                    class: "text-xs tsuru-btn-primary py-1 px-3" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Fila N2 (analistas) %>
    <% if (@pending_n2&.any?) %>
      <div>
        <h2 class="text-lg font-semibold text-primary-900 mb-3">Aguardando avaliação N2</h2>
        <div class="space-y-2">
          <% @pending_n2.each do |d| %>
            <div class="tsuru-card flex items-center justify-between py-3 border-l-4 border-success-400">
              <div>
                <%= link_to d.title, demand_path(d), class: "font-medium text-primary-800 hover:underline text-sm" %>
                <p class="text-xs text-gray-400 mt-0.5">por <%= d.user.display_name %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
