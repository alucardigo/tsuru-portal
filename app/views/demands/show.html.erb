<div class="max-w-3xl mx-auto">
  <%= link_to "← Demandas", demands_path, class: "text-sm text-gray-500 hover:text-primary-700" %>

  <div class="tsuru-card mt-4">
    <div class="flex items-start justify-between mb-4">
      <h1 class="text-2xl font-bold text-primary-900"><%= @demand.title %></h1>
      <span class="tsuru-badge-<%= @demand.aasm_state %> ml-4 shrink-0"><%= @demand.aasm_state.humanize %></span>
    </div>

    <p class="text-gray-700 whitespace-pre-line mb-6"><%= @demand.description %></p>

    <% if @demand.n1_flags.any? { |_, v| v } %>
      <div class="bg-danger-50 border border-danger-200 rounded-lg p-3 mb-4">
        <p class="text-xs font-semibold text-danger-700 mb-1">Flags N1 identificados:</p>
        <ul class="text-xs text-danger-600 list-disc list-inside">
          <% @demand.n1_flags.select { |_, v| v }.each_key do |flag| %>
            <li><%= flag.humanize %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="text-xs text-gray-400 border-t border-gray-100 pt-3">
      Criada por <%= @demand.user.display_name %> em <%= l @demand.created_at, format: :short %>
    </div>
  </div>

  <%# Ações de estado %>
  <div class="flex flex-wrap gap-2 mt-4">
    <% if policy(@demand).submeter? %>
      <%= button_to "Submeter para triagem", submeter_demand_path(@demand), method: :patch,
            class: "tsuru-btn-primary",
            data: { turbo_confirm: "Confirma a submissão?" } %>
    <% end %>

    <% if policy(@demand).iniciar_triagem? && @demand.submetida? %>
      <%= button_to "Iniciar triagem N1", iniciar_triagem_demand_path(@demand), method: :patch,
            class: "tsuru-btn-secondary" %>
    <% end %>

    <% if policy(@demand).triagem? && @demand.em_triagem? %>
      <%= link_to "Formulário N1", triagem_demand_path(@demand), class: "tsuru-btn-secondary" %>
    <% end %>

    <% if policy(@demand).update? %>
      <%= link_to "Editar", edit_demand_path(@demand), class: "tsuru-btn-secondary" %>
    <% end %>
  </div>

  <%# Comentários %>
  <div class="mt-8">
    <h2 class="text-lg font-semibold text-primary-900 mb-4">Comentários</h2>

    <div id="comments" class="space-y-3 mb-4">
      <% @demand.comments.order(:created_at).each do |comment| %>
        <%= render "comments/comment", comment: comment %>
      <% end %>
    </div>

    <%# Formulário novo comentário %>
    <div class="tsuru-card bg-gray-50">
      <%= form_with model: [ @demand, Comment.new ], data: { turbo: true } do |f| %>
        <%= f.text_area :body, rows: 3, class: "tsuru-input mb-3",
              placeholder: "Adicionar comentário técnico..." %>
        <%= f.submit "Comentar", class: "tsuru-btn-secondary" %>
      <% end %>
    </div>
  </div>
</div>
