<div class="max-w-3xl mx-auto">
  <%= link_to "← Demandas", demands_path, class: "text-sm text-gray-500 hover:text-primary-700" %>

  <div class="tsuru-card mt-4">
    <div class="flex items-start justify-between mb-4">
      <h1 class="text-2xl font-bold text-primary-900"><%= @demand.title %></h1>
      <span class="tsuru-badge-<%= @demand.aasm_state %> ml-4"><%= @demand.aasm_state.humanize %></span>
    </div>

    <p class="text-gray-700 whitespace-pre-line mb-6"><%= @demand.description %></p>

    <div class="text-xs text-gray-400 border-t border-gray-100 pt-3">
      Criada por <%= @demand.user.display_name %> em <%= l @demand.created_at, format: :short %>
    </div>
  </div>

  <% if policy(@demand).submeter? %>
    <div class="mt-4">
      <%= button_to "Submeter para triagem", submeter_demand_path(@demand), method: :patch,
            class: "tsuru-btn-primary",
            data: { turbo_confirm: "Confirma a submissão da demanda?" } %>
    </div>
  <% end %>

  <% if policy(@demand).update? %>
    <div class="mt-2">
      <%= link_to "Editar", edit_demand_path(@demand), class: "tsuru-btn-secondary" %>
    </div>
  <% end %>
</div>
