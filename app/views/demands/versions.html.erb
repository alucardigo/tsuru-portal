<% content_for :title, "Histórico completo" %>
<% content_for :nav_active, "demandas" %>
<% content_for :crumb, "#{@demand.codigo_display} · #{@demand.title.truncate(60)}" %>
<% content_for :subtitle, "· histórico completo" %>

<%
  human_field = lambda do |raw|
    label = {
      "aasm_state"        => "estado",
      "title"             => "título",
      "description"       => "descrição",
      "trl"               => "TRL",
      "parecer_tecnico"   => "parecer técnico",
      "n1_flags"          => "flags N1",
      "n2_assessment"     => "avaliação N2",
      "ods_goals"         => "ODS",
      "converted_task_id" => "tarefa de conversão",
      "conversion_note"   => "nota de conversão",
      "sankhya_record_id" => "vínculo Sankhya"
    }[raw.to_s]
    label || raw.to_s.humanize
  end

  format_change = lambda do |val|
    if val.nil? || val == ""
      "—"
    elsif val.is_a?(Hash) || val.is_a?(Array)
      val.to_json.truncate(80)
    else
      val.to_s.truncate(80)
    end
  end

  actor_name = ->(actor) { actor&.display_name || "Sistema" }
%>

<div class="max-w-[820px] mx-auto px-12 py-8">
  <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6">
    <div class="flex items-start gap-3">
      <div class="w-9 h-9 rounded-md bg-gray-900 text-white flex items-center justify-center">
        <%= icon(:doc, size: 20) %>
      </div>
      <div class="flex-1">
        <div class="text-[13.5px] font-semibold text-gray-900">Histórico completo</div>
        <div class="text-[12px] text-gray-600 leading-relaxed mt-0.5">
          Transições de estado, comentários, documentos anexados e alterações de campo, tudo numa
          única linha do tempo — rastreabilidade completa para defesa Lei do Bem.
        </div>
      </div>
      <div class="shrink-0">
        <%= link_to demand_path(@demand), class: "tsuru-btn-secondary" do %>
          <%= icon(:arrow, size: 14, class_name: "rotate-180") %>
          <span>Voltar à demanda</span>
        <% end %>
      </div>
    </div>
  </div>

  <% if @events.empty? %>
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
      <div class="text-[13px] text-gray-500">Nenhum evento registrado até o momento.</div>
    </div>
  <% else %>
    <div class="subhead mb-3"><%= @events.size %> evento<%= "s" if @events.size != 1 %></div>

    <ol class="relative border-l-2 border-gray-100 ml-3 space-y-0">
      <% @events.each do |ev| %>
        <li class="relative pl-6 pb-6 last:pb-0">
          <% case ev.type
             when :transition
               dot = "bg-indigo-500"; ring = "ring-indigo-100"
             when :comment
               dot = "bg-teal-500"; ring = "ring-teal-100"
             when :document
               dot = "bg-amber-500"; ring = "ring-amber-100"
             else
               dot = ev.payload[:event] == "create" ? "bg-emerald-500" : "bg-blue-500"
               ring = ev.payload[:event] == "create" ? "ring-emerald-100" : "ring-blue-100"
             end %>
          <span class="absolute -left-[7px] top-1 w-3 h-3 rounded-full <%= dot %> ring-4 <%= ring %>" aria-hidden="true"></span>

          <div class="bg-white rounded-lg border border-gray-200 p-3.5 hover:border-gray-300 transition-colors">
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-2 min-w-0">
                <% if ev.actor %>
                  <%= avatar(ev.actor, size: 22) %>
                <% else %>
                  <span class="inline-flex items-center justify-center w-[22px] h-[22px] rounded-full bg-gray-100 text-gray-500 text-[10px] font-semibold">SY</span>
                <% end %>
                <div class="text-[12.5px] text-gray-900 min-w-0">
                  <span class="font-medium"><%= actor_name.call(ev.actor) %></span>
                  <% case ev.type %>
                  <% when :transition %>
                    <span class="text-gray-500">mudou o estado</span>
                    <%= pill("#{UiHelper::STATUS_LABELS[ev.payload[:from_state]] || ev.payload[:from_state] || 'início'} → #{UiHelper::STATUS_LABELS[ev.payload[:to_state]] || ev.payload[:to_state]}", color: "indigo") %>
                  <% when :comment %>
                    <span class="text-gray-500">comentou</span>
                  <% when :document %>
                    <span class="text-gray-500">anexou um documento</span>
                  <% else %>
                    <span class="text-gray-500"><%= { "create" => "criou", "update" => "atualizou", "destroy" => "removeu" }[ev.payload[:event]] || ev.payload[:event] %> a demanda</span>
                  <% end %>
                </div>
              </div>
              <div class="shrink-0 text-[11px] text-gray-400 font-mono"
                   title="<%= l(ev.created_at, format: :long) rescue ev.created_at.strftime("%d/%m/%Y %H:%M:%S") %>">
                <%= l(ev.created_at, format: :short) %>
              </div>
            </div>

            <% case ev.type %>
            <% when :transition %>
              <% if ev.payload[:justification].present? %>
                <div class="mt-2.5 pt-2.5 border-t border-gray-100 text-[12px] text-gray-700 whitespace-pre-line"><%= ev.payload[:justification] %></div>
              <% end %>
            <% when :comment %>
              <div class="mt-2.5 pt-2.5 border-t border-gray-100 text-[12.5px] text-gray-700 whitespace-pre-line"><%= ev.payload[:body] %></div>
            <% when :document %>
              <div class="mt-2.5 pt-2.5 border-t border-gray-100 text-[12px] text-gray-700 flex items-center gap-1.5">
                <%= icon(:file, size: 12, class_name: "text-gray-400") %>
                <%= link_to ev.payload[:filename], rails_blob_path(ev.payload[:blob], disposition: "attachment"), class: "hover:underline" %>
                <span class="text-gray-400">· <%= number_to_human_size(ev.payload[:byte_size]) %></span>
              </div>
            <% else %>
              <% if ev.payload[:changes].present? %>
                <div class="mt-3 pt-3 border-t border-gray-100 space-y-1.5">
                  <% ev.payload[:changes].each do |field, change_pair|
                       before, after = Array(change_pair) %>
                    <div class="grid grid-cols-[120px_1fr] gap-3 text-[12px] items-baseline">
                      <div class="text-gray-500 truncate" title="<%= field %>"><%= human_field.call(field) %></div>
                      <div class="min-w-0">
                        <% if ev.payload[:event] == "create" %>
                          <span class="text-emerald-700 break-words"><%= format_change.call(after) %></span>
                        <% else %>
                          <span class="inline-flex items-baseline gap-1.5 flex-wrap">
                            <span class="text-rose-600 line-through break-words"><%= format_change.call(before) %></span>
                            <span class="text-gray-400" aria-hidden="true">→</span>
                            <span class="text-emerald-700 break-words"><%= format_change.call(after) %></span>
                          </span>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ol>
  <% end %>
</div>
