<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-primary-900">Minhas Demandas</h1>
    <%= link_to "Nova Demanda", new_demand_path, class: "tsuru-btn-primary" %>
  </div>

  <% if @demands.empty? %>
    <div class="tsuru-card text-center py-12">
      <p class="text-gray-500 mb-4">Nenhuma demanda ainda.</p>
      <%= link_to "Criar primeira demanda", new_demand_path, class: "tsuru-btn-secondary" %>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @demands.each do |demand| %>
        <div class="tsuru-card flex items-center justify-between">
          <div>
            <h2 class="font-semibold text-primary-800"><%= demand.title %></h2>
            <p class="text-sm text-gray-500 mt-0.5">
              <%= demand.user.display_name %> ·
              <span class="tsuru-badge-<%= demand.aasm_state %>"><%= demand.aasm_state.humanize %></span>
            </p>
          </div>
          <%= link_to "Ver", demand_path(demand), class: "text-sm text-primary-700 hover:underline" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
