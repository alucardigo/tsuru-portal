<% content_for :title, "Editar Lei do Bem" %>
<% content_for :nav_active, "elegibilidade" %>
<% content_for :crumb, "DEM-#{@demand.id.to_s.rjust(4, '0')} · Lei do Bem" %>
<% content_for :subtitle, "· Configuração" %>

<div class="max-w-[720px] mx-auto px-7 py-6">
  <div class="mb-5 flex items-baseline justify-between">
    <div>
      <div class="text-[22px] font-semibold tracking-tight text-gray-900">Configuração Lei do Bem</div>
      <p class="text-[13px] text-gray-500 mt-1">Ajuste dados gerais do projeto PD&I.</p>
    </div>
    <%= link_to "Voltar ao painel", demand_lei_do_bem_record_path(@demand), class: "text-[12.5px] text-gray-600 hover:text-gray-900" %>
  </div>

  <div class="tsuru-card p-6">
    <%= render "form", record: @record, demand: @demand %>
  </div>
</div>
