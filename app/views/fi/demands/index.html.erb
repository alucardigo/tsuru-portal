<% content_for :title, "Fila de avaliação FI" %>
<% content_for :nav_active, "fi" %>
<% content_for :crumb, "FI Group" %>
<% content_for :subtitle, "· parecer de elegibilidade Lei do Bem" %>

<div class="max-w-[1180px] mx-auto px-7 py-6">
  <%# Hero %>
  <div class="mb-5">
    <div class="text-[26px] font-semibold tracking-tight text-gray-900">Fila de avaliação FI</div>
    <p class="text-[13px] text-gray-500 mt-1">
      Demandas com avaliação técnica concluída aguardando o parecer de elegibilidade da FI Group para a Lei do Bem.
    </p>
  </div>

  <%# Contagem %>
  <div class="mb-6">
    <div class="tsuru-card p-4 inline-flex items-center gap-3">
      <%= icon(:inbox, size: 18, class_name: "text-gray-400") %>
      <div>
        <div class="text-[22px] font-semibold tracking-tight text-gray-900 leading-none">
          <%= @pagy.count %>
        </div>
        <div class="text-[11px] text-gray-500 mt-1">
          <%= @pagy.count == 1 ? "demanda aguardando parecer" : "demandas aguardando parecer" %>
        </div>
      </div>
    </div>
  </div>

  <%# Lista de demandas %>
  <% if @pagy.count.zero? %>
    <div class="tsuru-card p-12 text-center">
      <%= icon(:inbox, size: 36, class_name: "mx-auto text-gray-300 mb-3") %>
      <div class="text-[14px] font-semibold text-gray-900">Tudo em dia</div>
      <p class="text-[12.5px] text-gray-500 mt-1">Nenhuma demanda aguardando parecer da FI no momento.</p>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @demands.each do |demand| %>
        <div class="tsuru-card p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 text-[11px] text-gray-500">
                <span class="font-mono text-gray-700"><%= demand.codigo_display %></span>
                <span class="text-gray-300">·</span>
                <span><%= demand.user.display_name %></span>
                <span class="text-gray-300">·</span>
                <span><%= demand.etapa_label %></span>
              </div>
              <div class="mt-1 text-[15px] font-semibold text-gray-900"><%= demand.title %></div>
              <% if demand.barreira_tecnica.present? %>
                <p class="text-[12.5px] text-gray-700 mt-1.5 leading-relaxed line-clamp-2">
                  <strong>Barreira:</strong> <%= demand.barreira_tecnica.truncate(220) %>
                </p>
              <% end %>
            </div>
            <div class="text-right shrink-0 flex flex-col items-end gap-2">
              <%= status_pill(demand.etapa_funil) %>
              <%= link_to "Analisar →", fi_demand_path(demand), class: "tsuru-btn-primary !h-7 !text-[11.5px] !px-2.5" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <nav aria-label="paginação" class="flex justify-center mt-5 text-[12px] text-gray-600">
        <%== @pagy.series_nav %>
      </nav>
    <% end %>
  <% end %>
</div>
